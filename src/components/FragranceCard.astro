---
import NoteRow from "@/components/NoteRow.astro";
import { HOUSE_LABELS, TIER_LABELS, type Fragrance } from "@/lib/types";
import { shopLinks, initials, fragranceImage, genderOf, performanceOf } from "@/data/fragrances";

interface Props {
  f: Fragrance;
  index: number;
}
const { f, index } = Astro.props;
const links = shopLinks(f);
const ini = initials(f.brand);
const img = fragranceImage(f.id);
const gender = genderOf(f);
const genderLabel = { men: "Men", women: "Women", unisex: "Unisex" }[gender];
const perf = performanceOf(f);
const searchText = [
  f.brand, f.name, ...f.families,
  ...f.notes.top, ...f.notes.middle, ...f.notes.base,
].join(" ").toLowerCase();
const delay = (index % 4) * 80;
---

<article
  class="card-wrap"
  data-season={f.season}
  data-times={f.times.join(" ")}
  data-house={f.houseType}
  data-price={f.priceTier}
  data-gender={genderOf(f)}
  data-sillage={perf.sillage}
  data-projection={perf.projection}
  data-families={f.families.join(" ")}
  data-search={searchText}
  data-reveal
  style={`--reveal-delay:${delay}ms`}
>
  <button
    type="button"
    class="card group relative flex h-full w-full flex-col overflow-hidden rounded-2xl p-5 text-left"
    data-open-drawer
    data-id={f.id}
    data-brand={f.brand}
    data-name={f.name}
    data-desc={f.description}
    data-house={HOUSE_LABELS[f.houseType]}
    data-price={TIER_LABELS[f.priceTier]}
    data-season={f.season}
    data-times={f.times.join(" ")}
    data-top={f.notes.top.join(", ")}
    data-mid={f.notes.middle.join(", ")}
    data-base={f.notes.base.join(", ")}
    data-families={f.families.join(", ")}
    data-from={f.accent[0]}
    data-to={f.accent[1]}
    data-initials={ini}
    data-image={img}
    data-amazon={links.amazon}
    data-sillage={perf.sillage}
    data-projection={perf.projection}
  >
    <!-- bottle stage -->
    <div class="card-stage relative mb-5 flex h-44 items-center justify-center">
      <div
        class="card-glow absolute inset-0 m-auto h-32 w-32 rounded-full"
        style={`background:radial-gradient(circle, ${f.accent[0]}, transparent 70%)`}
      >
      </div>
      <div class="bottle-img relative flex h-40 items-center justify-center">
        <img
          src={img}
          alt={`${f.brand} ${f.name} bottle`}
          loading="lazy"
          decoding="async"
          class="h-full w-auto max-w-[70%] object-contain drop-shadow-[0_18px_28px_rgba(0,0,0,0.45)]"
        />
      </div>
      <!-- gender corner tag -->
      <span
        class="absolute left-0 top-0 rounded-full border px-2.5 py-1 text-[0.55rem] uppercase tracking-[0.16em]"
        style="border-color:var(--border);color:var(--text-faint);background:var(--surface)"
      >
        {genderLabel}
      </span>
      <!-- season / tier corner tag -->
      <span
        class="absolute right-0 top-0 rounded-full border px-2.5 py-1 text-[0.55rem] uppercase tracking-[0.16em]"
        style="border-color:var(--border);color:var(--text-faint);background:var(--surface)"
      >
        {f.priceTier === "premium" ? "Premium" : "Budget"}
      </span>
    </div>

    <!-- BRAND — top priority -->
    <h3 class="text-xl font-bold leading-tight tracking-tight">{f.brand}</h3>
    <!-- model / fragrance name — secondary -->
    <p
      class="mt-0.5 text-sm font-light"
      style="color:var(--text-muted)"
    >
      {f.name}
    </p>

    <!-- note pyramid -->
    <div
      class="card-notes mt-4 space-y-2.5 border-t pt-4"
      style="border-color:var(--border)"
    >
      <NoteRow tier="top" notes={f.notes.top} />
      <NoteRow tier="middle" notes={f.notes.middle} />
      <NoteRow tier="base" notes={f.notes.base} />
    </div>

    <!-- action -->
    <div class="card-actions mt-5 flex items-center justify-between gap-2">
      <a
        href={links.amazon}
        target="_blank"
        rel="noopener"
        data-stop
        class="card-amazon link-underline inline-flex items-center gap-1.5 text-xs font-semibold uppercase tracking-[0.16em]"
        style="color:var(--accent)"
      >
        Find on Amazon
        <svg
          width="13"
          height="13"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          ><path d="M7 17 17 7M7 7h10v10"></path></svg
        >
      </a>
      <div class="flex items-center gap-2.5">
        <!-- span (not <button>) because the whole card is itself a <button>;
             a nested button would force the parser to close the card early -->
        <span
          role="button"
          tabindex="0"
          data-stop
          data-wish
          data-id={f.id}
          aria-pressed="false"
          aria-label={`Add ${f.brand} ${f.name} to wishlist`}
          title="Add to wishlist"
          class="wish-btn grid h-7 w-7 cursor-pointer place-items-center rounded-full border"
          style="border-color:var(--border-strong)"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.6l-1-1a5.5 5.5 0 1 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8Z"></path></svg>
        </span>
        <span
          class="card-details text-[0.6rem] uppercase tracking-[0.18em]"
          style="color:var(--text-faint)">Details +</span
        >
      </div>
    </div>
  </button>
</article>
