---
// A single tier of the fragrance note pyramid with a small line icon.
interface Props {
  tier: "top" | "middle" | "base";
  notes: string[];
}
const { tier, notes } = Astro.props;

const labels = { top: "Top", middle: "Heart", base: "Base" } as const;
---

<div class="flex items-start gap-2.5">
  <span
    class="mt-0.5 shrink-0"
    style="color:var(--accent)"
    aria-hidden="true"
  >
    {
      tier === "top" && (
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 3v6" />
          <path d="M12 9c-3 0-5 2-5 5a5 5 0 0 0 10 0c0-3-2-5-5-5Z" />
          <path d="M9 4c1.5.5 3 .5 3 2" />
        </svg>
      )
    }
    {
      tier === "middle" && (
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="2.5" />
          <path d="M12 9.5c0-2.5 1-4.5 0-6.5-1 2 0 4 0 6.5Z" />
          <path d="M12 14.5c0 2.5-1 4.5 0 6.5 1-2 0-4 0-6.5Z" />
          <path d="M9.5 12c-2.5 0-4.5-1-6.5 0 2 1 4 0 6.5 0Z" />
          <path d="M14.5 12c2.5 0 4.5 1 6.5 0-2-1-4 0-6.5 0Z" />
        </svg>
      )
    }
    {
      tier === "base" && (
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 4 3 9l9 5 9-5-9-5Z" />
          <path d="M3 14l9 5 9-5" />
        </svg>
      )
    }
  </span>

  <div class="min-w-0">
    <span
      class="mr-2 text-[0.6rem] font-semibold uppercase tracking-[0.14em]"
      style="color:var(--text-faint)">{labels[tier]}</span
    >
    <span class="text-xs" style="color:var(--text-muted)">{notes.join(", ")}</span>
  </div>
</div>
