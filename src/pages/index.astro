      { label: "Crisp, breathable linen or raw cotton.", effects: { "p:Fresh": 1, "p:Aquatic": 1 } },
      { label: "Heavy warm suede or smooth distressed leather.", effects: { "p:Leather": 2, "p:Woody": 1 } },
