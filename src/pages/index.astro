    ]},
    { phase: "Fashion & Persona", q: "How do you want to feel when you spray this on?", options: [
      { label: "Energised, refreshed, and hyper-focused.", effects: { "p:Citrus": 1, "p:Fresh": 1 } },
      { label: "Confident, commanding, and powerful.", effects: { "p:Woody": 1, "p:Leather": 1, "proj:High": 1 } },
      { label: "Sensual, mysterious, and alluring.", effects: { "p:Sweet": 1, "p:Spicy": 1 } },
    ]},
    { phase: "Fashion & Persona", q: "One word to define your personal brand:", options: [
      { label: "Effortless", effects: { "p:Fresh": 1, designer: 1 } },
      { label: "Commanding", effects: { "p:Woody": 1, "p:Leather": 1 } },
      { label: "Unconventional", effects: { niche: 2 } },
      { label: "Luxurious", effects: { "pb:luxury": 2 } },
    ]},
  ];

  const quizEl = document.getElementById("quiz");
  const stageEl = document.getElementById("quiz-stage");
  const phaseEl = document.getElementById("quiz-phase");
  const counterEl = document.getElementById("quiz-counter");
  const progressEl = document.getElementById("quiz-progress");
  const KEYS = ["A", "B", "C", "D", "E"];
  const answers: number[] = [];
  let qi = 0;

  type Band = "value" | "mid" | "luxury";
  type ScoreState = {
    summer: number; winter: number; day: number; night: number;
    designer: number; niche: number;
    bands: { value: number; mid: number; luxury: number };
    gender: { men: number; women: number; unisex: number };
    profiles: Record<string, number>;
    projection: { Low: number; Moderate: number; High: number };
  };
  function blankState(): ScoreState {
    return {
      summer: 0, winter: 0, day: 0, night: 0,
      designer: 0, niche: 0,
      bands: { value: 0, mid: 0, luxury: 0 },
      gender: { men: 0, women: 0, unisex: 0 },
      profiles: {}, projection: { Low: 0, Moderate: 0, High: 0 },
    };
  }
  function buildState(): ScoreState {
    const s = blankState();
    answers.forEach((ans, idx) => {
      const eff = QUESTIONS[idx]?.options[ans]?.effects;
      if (!eff) return;
      for (const [k, v] of Object.entries(eff)) {
        if (k.startsWith("p:")) s.profiles[k.slice(2)] = (s.profiles[k.slice(2)] || 0) + v;
        else if (k.startsWith("proj:")) s.projection[k.slice(5) as "Low" | "Moderate" | "High"] += v;
        else if (k.startsWith("pb:")) s.bands[k.slice(3) as Band] += v;
        else if (k.startsWith("g:")) s.gender[k.slice(2) as "men" | "women" | "unisex"] += v;
        else (s as any)[k] += v;
      }
    });
    return s;
  }

  // Derive a projection tier for a fragrance from its season / time / families.
  function fragProjection(f: QFrag): "Low" | "Moderate" | "High" {
    let p = f.season === "winter" ? 2 : -1;
    if (f.times.includes("night")) p += 1;
    const fam = f.families;
    if (fam.includes("Gourmand")) p += 2;
    if (fam.includes("Sweet")) p += 1;
    if (fam.includes("Spicy")) p += 1;
    if (fam.includes("Leather")) p += 2;
    if (fam.includes("Woody")) p += 1;
    if (fam.includes("Citrus")) p -= 2;
    if (fam.includes("Aquatic")) p -= 2;
    if (fam.includes("Fresh")) p -= 1;
    if (p >= 4) return "High";
    if (p <= 0) return "Low";
    return "Moderate";
  }

  function matchScore(f: QFrag, s: ScoreState): number {
    let score = 0;
    score += f.season === "summer" ? s.summer : s.winter;
    for (const t of f.times) score += (t === "day" ? s.day : s.night) * 0.5;
    score += f.houseType === "designer" ? s.designer : s.niche;
    score += (s.bands[f.priceBand] || 0) * 0.6;
    for (const fam of f.families) score += s.profiles[fam] || 0;
    score += s.projection[fragProjection(f)] || 0;
    return score;
  }

  function recommend() {
    const s = buildState();
    let pool = quizFrags.slice();
    // Base filter: highest-scored gender (men excludes women's & vice-versa;
    // unisex keeps everything).
    const topGender = (["men", "women", "unisex"] as const).reduce(
      (a, b) => (s.gender[b] > s.gender[a] ? b : a), "men" as "men" | "women" | "unisex");
    if (topGender === "men") pool = pool.filter((f) => f.gender !== "women");
    else if (topGender === "women") pool = pool.filter((f) => f.gender !== "men");
    if (pool.length === 0) pool = quizFrags.slice();
    // Price band: bias to the chosen band, widening to neighbours if the strict
    // band is too sparse (the sub-₹1,600 "value" tier is small).
    const bandOrder: Band[] = ["value", "mid", "luxury"];
    const topBand = bandOrder.reduce(
      (a, b) => (s.bands[b] > s.bands[a] ? b : a), "value" as Band);
    if (s.bands[topBand] > 0) {
      const ti = bandOrder.indexOf(topBand);
      const allowed = new Set<Band>([topBand]);
      let banded = pool.filter((f) => allowed.has(f.priceBand));
      for (let r = 1; banded.length < 8 && r < 3; r++) {
        if (ti - r >= 0) allowed.add(bandOrder[ti - r]);
        if (ti + r <= 2) allowed.add(bandOrder[ti + r]);
        banded = pool.filter((f) => allowed.has(f.priceBand));
      }
      if (banded.length) pool = banded;
    }
    if (pool.length === 0) pool = quizFrags.slice();

    const scored = pool
      .map((f) => ({ f, score: matchScore(f, s) }))
      .sort((a, b) => b.score - a.score);
    const used = new Set<string>();
    const pick = (test: (f: QFrag) => boolean): QFrag | undefined => {
      for (const it of scored) if (!used.has(it.f.id) && test(it.f)) { used.add(it.f.id); return it.f; }
      for (const it of scored) if (test(it.f)) return it.f;
      return scored[0]?.f;
    };
    return [
      { label: "Top for Summer", f: pick((f) => f.season === "summer") },
      { label: "Top for Winter", f: pick((f) => f.season === "winter") },
      { label: "Top for Day", f: pick((f) => f.times.includes("day")) },
      { label: "Top for Night", f: pick((f) => f.times.includes("night")) },
    ];
  }

  function setProgress(label: string, counter: string, pct: number) {
    if (phaseEl) phaseEl.textContent = label;
    if (counterEl) counterEl.textContent = counter;
    if (progressEl) (progressEl as HTMLElement).style.width = `${pct}%`;
  }

  function renderQuestion() {
    if (!stageEl) return;
    const q = QUESTIONS[qi];
    setProgress(q.phase, `${qi + 1} / ${QUESTIONS.length}`, ((qi + 1) / QUESTIONS.length) * 100);
    stageEl.innerHTML = `
      <div class="quiz-q">
        <p class="eyebrow">Question ${qi + 1}</p>
        <h2 class="font-display mt-3 text-2xl font-light leading-snug tracking-tight md:text-4xl">${q.q}</h2>
        <div class="mt-8 flex flex-col gap-3">
          ${q.options.map((o, i) => `
            <button class="quiz-opt" data-opt="${i}">
              <span class="opt-key">${KEYS[i]}</span>
              <span class="pt-0.5 text-sm md:text-base">${o.label}</span>
            </button>`).join("")}
        </div>
        ${qi > 0 ? `<button id="quiz-back" class="mt-7 text-xs uppercase tracking-[0.18em]" style="color:var(--text-faint)">← Back</button>` : ""}
      </div>`;
    stageEl.querySelectorAll<HTMLButtonElement>(".quiz-opt").forEach((btn) => {
      btn.addEventListener("click", () => choose(parseInt(btn.dataset.opt || "0", 10)));
    });
    document.getElementById("quiz-back")?.addEventListener("click", () => { if (qi > 0) { qi--; renderQuestion(); } });
    document.querySelector(".quiz-scroll")?.scrollTo({ top: 0 });
  }

  function choose(i: number) {
    answers[qi] = i;
    if (qi >= QUESTIONS.length - 1) renderResults();
    else { qi++; renderQuestion(); }
  }

  function renderResults() {
    if (!stageEl) return;
    setProgress("Your Edit", "Done", 100);
    const recs = recommend();
    const cards = recs.map((r) => {
      const f = r.f;
      if (!f) return "";
      return `
        <div class="quiz-result-card group flex h-full cursor-pointer flex-col items-center p-4 text-center sm:items-start sm:text-left" role="button" tabindex="0" data-result-id="${f.id}" data-amazon="${localizeAmazon(f.amazon)}">
          <div class="flex w-full items-start justify-between gap-2">
            <span class="pt-1 text-[0.6rem] uppercase tracking-[0.2em]" style="color:var(--accent)">${r.label}</span>
            <div class="flex shrink-0 items-center gap-2">
              <button type="button" data-stop data-wish data-id="${f.id}" aria-pressed="false" aria-label="Add ${f.brand} ${f.name} to wishlist" title="Add to wishlist" class="wish-btn grid h-8 w-8 shrink-0 place-items-center rounded-full border" style="border-color:var(--border-strong);background:var(--bg-soft)">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.6l-1-1a5.5 5.5 0 1 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8Z"></path></svg>
              </button>
            </div>
          </div>
          <div class="relative my-3 flex h-36 w-full items-center justify-center">
            <div class="absolute inset-0 m-auto h-24 w-24 rounded-full" style="background:radial-gradient(circle, ${f.accent[0]}, transparent 70%);filter:blur(28px);opacity:.5"></div>
            <img src="${f.image}" alt="${f.brand} ${f.name}" class="relative h-full w-auto object-contain" />
          </div>
          <span class="text-base font-bold leading-tight">${f.brand}</span>
          <span class="text-sm font-light" style="color:var(--text-muted)">${f.name}</span>
          <button type="button" data-stop data-view-details class="mt-auto pt-3 text-[0.6rem] uppercase tracking-[0.18em] transition-opacity hover:opacity-70" style="color:var(--accent)">View details +</button>
        </div>`;
    }).join("");
    stageEl.innerHTML = `
      <div class="quiz-q">
        <p class="eyebrow">Your Signature Edit</p>
        <h2 class="font-display mt-3 text-3xl font-light tracking-tight md:text-5xl">Four scents, chosen for you.</h2>
        <p class="mt-4 max-w-xl text-sm" style="color:var(--text-muted)">Based on your ${QUESTIONS.length} answers — the best match for each season and time of day, within your budget.</p>
        <div class="mt-8 grid grid-cols-2 gap-4 lg:grid-cols-4">${cards}</div>
        <div class="mt-9 flex flex-col gap-3 sm:flex-row">
          <button id="quiz-wishlist-all" class="btn-accent inline-flex items-center justify-center gap-2 rounded-full px-6 py-3 text-xs uppercase tracking-[0.18em]">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.6l-1-1a5.5 5.5 0 1 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8Z"></path></svg>
            Add to Wishlist
          </button>
          <button id="quiz-restart" class="btn-ghost rounded-full px-6 py-3 text-xs uppercase tracking-[0.18em]">Retake quiz</button>
          <button id="quiz-explore" class="btn-ghost rounded-full px-6 py-3 text-xs uppercase tracking-[0.18em]">Explore full catalog</button>
        </div>
      </div>`;
    const recIds = recs.map((r) => r.f?.id).filter(Boolean) as string[];
    stageEl.querySelectorAll<HTMLElement>("[data-result-id]").forEach((card) => {
      // The card body takes the visitor straight to Amazon; "View details"
      // (a data-stop button) layers the drawer on top of the results instead.
      const goAmazon = (e: Event) => {
        if ((e.target as HTMLElement).closest("[data-stop]")) return; // heart & view-details handled separately
        const url = card.dataset.amazon;
        if (url) window.open(url, "_blank", "noopener");
      };
      card.addEventListener("click", goAmazon);
      card.addEventListener("keydown", (e) => { if (e.key === "Enter" || e.key === " ") { e.preventDefault(); goAmazon(e); } });
      // Keep the quiz results open underneath; the drawer layers on top, so
      // closing the drawer returns to the four assorted picks.
      card.querySelector<HTMLElement>("[data-view-details]")?.addEventListener("click", () => {
        const id = card.dataset.resultId || "";
        const gridBtn = document.querySelector<HTMLElement>(`#grid [data-open-drawer][data-id="${id}"]`);
        if (gridBtn) openDrawer(gridBtn);
      });
    });
    const wishAllBtn = document.getElementById("quiz-wishlist-all");
    wishAllBtn?.addEventListener("click", function saveAll() {
      // Save all four picks to the wishlist and stay on the results — the quiz
      // only closes when the visitor taps the close (X) button. Gate behind
      // sign-in like any other save; the retry re-runs this same handler.
      if (!ensureSignedIn(saveAll)) return;
      recIds.forEach((id) => wishlist.add(id));
      saveWishlist();
      syncWishUI();
      if (wishAllBtn) wishAllBtn.innerHTML = `
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
        Saved to Wishlist`;
    });
    bindWishButtons(stageEl);
    syncWishUI();
    document.getElementById("quiz-restart")?.addEventListener("click", startQuiz);
    document.getElementById("quiz-explore")?.addEventListener("click", () => {
      // Scenario 2: visitor hearted picks individually, now heads to the catalogue.
      closeQuiz(() => document.getElementById("catalogue")?.scrollIntoView({ behavior: "smooth" }));
    });
    document.querySelector(".quiz-scroll")?.scrollTo({ top: 0 });
  }

  function startQuiz() { qi = 0; answers.length = 0; quizEl?.classList.remove("closing"); quizEl?.classList.add("open"); document.body.style.overflow = "hidden"; renderQuestion(); frOpen("quiz", doCloseQuizDOM); }
  // Dissolve-close: fade the overlay out before tearing it down, so leaving the
  // quiz never feels abrupt. `after` runs once the fade completes (e.g. scroll).
  let quizClosing = 0;
  let pendingQuizAfter: (() => void) | undefined;
  function doCloseQuizDOM() {
    if (!quizEl || !quizEl.classList.contains("open")) {
      const a = pendingQuizAfter; pendingQuizAfter = undefined; a?.(); return;
    }
    quizEl.classList.add("closing");
    window.clearTimeout(quizClosing);
    quizClosing = window.setTimeout(() => {
      quizEl.classList.remove("open", "closing");
      document.body.style.overflow = document.getElementById("drawer")?.classList.contains("open") ? "hidden" : "";
      const a = pendingQuizAfter; pendingQuizAfter = undefined; a?.();
    }, 460);
  }
  function closeQuiz(after?: () => void) {
    pendingQuizAfter = after;
    if (frRequestClose("quiz")) return; // history rewind runs doCloseQuizDOM
    doCloseQuizDOM();
  }

  document.getElementById("open-quiz")?.addEventListener("click", startQuiz);
  document.getElementById("quiz-close")?.addEventListener("click", () => closeQuiz());

  // ─── Hero CTA: cursor-mask paint blob that "drags" toward the pointer ────
  const quizBtn = document.getElementById("open-quiz") as HTMLElement | null;
  if (quizBtn && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    let tx = 0, ty = 0, cx = 0, cy = 0, raf = 0, inside = false;
    const setVars = () => {
      quizBtn.style.setProperty("--mx", `${cx}px`);
      quizBtn.style.setProperty("--my", `${cy}px`);
    };
    const tick = () => {
      cx += (tx - cx) * 0.5; // higher factor = snappier, less "drag"/lag
      cy += (ty - cy) * 0.5;
      setVars();
      if (inside || Math.abs(tx - cx) > 0.4 || Math.abs(ty - cy) > 0.4) {
        raf = requestAnimationFrame(tick);
      } else raf = 0;
    };
    quizBtn.addEventListener("pointerenter", (e) => {
      inside = true;
      const r = quizBtn.getBoundingClientRect();
      tx = e.clientX - r.left; ty = e.clientY - r.top;
      cx = tx; cy = ty; // snap on entry so the blob doesn't fly in from a corner
      setVars();
      if (!raf) raf = requestAnimationFrame(tick);
    });
    quizBtn.addEventListener("pointermove", (e) => {
      const r = quizBtn.getBoundingClientRect();
      tx = e.clientX - r.left; ty = e.clientY - r.top;
      if (!raf) raf = requestAnimationFrame(tick);
    });
    quizBtn.addEventListener("pointerleave", () => { inside = false; });
  }

  document.addEventListener("keydown", (e) => {
    if (e.key !== "Escape") return;
    // The drawer's own Escape handler closes it first; don't also close the quiz.
    if (drawer?.classList.contains("open")) return;
    if (wishDrawer?.classList.contains("open")) { closeWishlist(); return; }
    if (quizEl?.classList.contains("open")) closeQuiz();
    if (dict?.classList.contains("open")) closeDict();
  });
</script>
