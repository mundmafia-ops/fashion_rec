      { label: "“Wow, you smell incredibly clean and fresh.”", effects: { summer: 1, day: 1, "p:Fresh": 1 } },
      { label: "“You smell mysterious, rich, and seductive.”", effects: { winter: 1, night: 1, "p:Spicy": 1 } },
