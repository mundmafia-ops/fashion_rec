---
import Layout from "@/layouts/Layout.astro";
import FragranceCard from "@/components/FragranceCard.astro";
import { fragrances, fragranceImage, genderOf } from "@/data/fragrances";
import { FAMILIES, GENDERS, type Gender } from "@/lib/types";

const total = fragrances.length;

// Build a 12-bottle carousel for a gender: 3 Summer · 3 Winter · 3 Day · 3 Night
// (Summer/Day share the warm pool, Winter/Night the cool pool.)
function buildCarousel(gender: Gender) {
  const pool = fragrances.filter((f) => genderOf(f) === gender);
  const warm = pool.filter((f) => f.season === "summer");
  const cool = pool.filter((f) => f.season === "winter");
  const slot = (f: (typeof fragrances)[number], group: string, temp: "warm" | "cool") => ({
    id: f.id, group, temp, brand: f.brand, name: f.name, image: fragranceImage(f.id),
  });
  return [
    ...warm.slice(0, 3).map((f) => slot(f, "Summer", "warm")),
    ...cool.slice(0, 3).map((f) => slot(f, "Winter", "cool")),
    ...warm.slice(3, 6).map((f) => slot(f, "Day", "warm")),
    ...cool.slice(3, 6).map((f) => slot(f, "Night", "cool")),
  ];
}

const carouselByGender = Object.fromEntries(
  GENDERS.map((g) => [g, buildCarousel(g)])
) as Record<Gender, ReturnType<typeof buildCarousel>>;

// Default render = men's set.
const carousel = carouselByGender.men;

const houses = [
  "Creed", "Xerjoff", "Roja Parfums", "Tom Ford", "Louis Vuitton",
  "Maison Francis Kurkdjian", "Amouage", "Parfums de Marly", "By Kilian",
  "Nishane", "Initio", "Lattafa",
];

const count = (pred: (f: (typeof fragrances)[number]) => boolean) =>
  fragrances.filter(pred).length;

const bigNav = [
  {
    value: "summer",
    label: "SUMMER",
    sub: "Bright & fresh",
    glow: "#ffcf52",
    n: count((f) => f.season === "summer"),
  },
  {
    value: "winter",
    label: "WINTER",
    sub: "Warm & cozy",
    glow: "#6aa9e6",
    n: count((f) => f.season === "winter"),
  },
  {
    value: "day",
    label: "DAY",
    sub: "Clean & sharp",
    glow: "#ffcf52",
    n: count((f) => f.times.includes("day")),
  },
  {
    value: "night",
    label: "NIGHT",
    sub: "Deep & bold",
    glow: "#6aa9e6",
    n: count((f) => f.times.includes("night")),
  },
];

// Lightweight fragrance payload for the client-side quiz scoring engine.
const quizFragrances = fragrances.map((f) => ({
  id: f.id,
  brand: f.brand,
  name: f.name,
  image: fragranceImage(f.id),
  season: f.season,
  times: f.times,
  houseType: f.houseType,
  priceTier: f.priceTier,
  gender: genderOf(f),
  families: f.families,
  accent: f.accent,
}));
---

<Layout>
  <!-- ───────────────────────── Header ───────────────────────── -->
  <header id="site-header" class="fixed inset-x-0 top-0 z-40 transition-all duration-500">
    <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-5 md:px-10">
      <a href="#top" class="font-display text-xl tracking-tight" style="letter-spacing:0.04em">
        FRAGRANDISE
      </a>
      <nav class="hidden items-center gap-8 md:flex lg:gap-10">
        <button class="nav-link link-underline text-xs uppercase tracking-[0.2em]" data-nav-mood="summer" style="color:var(--text-muted)">Summer</button>
        <button class="nav-link link-underline text-xs uppercase tracking-[0.2em]" data-nav-mood="winter" style="color:var(--text-muted)">Winter</button>
        <button class="nav-link link-underline text-xs uppercase tracking-[0.2em]" data-nav-mood="day" style="color:var(--text-muted)">Day</button>
        <button class="nav-link link-underline text-xs uppercase tracking-[0.2em]" data-nav-mood="night" style="color:var(--text-muted)">Night</button>
        <button id="open-dictionary" class="nav-dict inline-flex items-center gap-1.5 text-xs uppercase tracking-[0.2em]">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2Z"></path></svg>
          Dictionary
        </button>
      </nav>
      <div class="flex items-center gap-4">
        <button id="theme-toggle" class="theme-toggle" aria-label="Toggle light and dark mode" title="Toggle theme">
          <span class="knob">
            <svg id="icon-moon" width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"></path></svg>
            <svg id="icon-sun" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" style="display:none">
              <circle cx="12" cy="12" r="4"></circle>
              <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path>
            </svg>
          </span>
        </button>
        <button aria-label="Cart" class="grid h-9 w-9 place-items-center rounded-full border" style="border-color:var(--border-strong);color:var(--text-muted)">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path><path d="M3 6h18"></path><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
        </button>
      </div>
    </div>
  </header>

  <main id="top">
    <!-- ─────────── Hero with embedded bottle carousel ─────────── -->
    <section class="relative overflow-hidden px-6 pb-10 pt-32 md:px-10 md:pt-40">
      <div class="relative mx-auto grid w-full max-w-7xl items-end gap-12 lg:grid-cols-[1.05fr_0.95fr]">
        <!-- left: copy -->
        <div>
          <h1 class="font-display text-[2.7rem] font-light leading-[0.95] tracking-tight sm:text-6xl lg:text-[5rem]">
            <span class="hero-line"><span style="--d:120ms">A Guide for</span></span>
            <span class="hero-line"><span class="italic" style="--d:240ms;color:var(--accent)">Smelling Good.</span></span>
            <span class="hero-line"><span style="--d:360ms">Fashion Blended.</span></span>
          </h1>
          <p class="mt-8 max-w-md text-base leading-relaxed fade-in" style="--d:680ms;color:var(--text-muted)">
            Welcome to your personal fragrance journey. Explore our curated collection of exceptional scents, from exclusive luxury houses to brilliant everyday discoveries, all thoughtfully organized by season, occasion, and profile.
          </p>
          <div class="mt-9 flex w-full max-w-md flex-col items-stretch gap-3.5 fade-in" style="--d:760ms">
            <span class="quiz-btn-wrap">
              <span class="quiz-aura" aria-hidden="true"></span>
              <button id="open-quiz" type="button" class="btn-accent btn-hero-primary inline-flex w-full items-center justify-center gap-3 overflow-hidden rounded-full px-10 py-5 text-sm font-semibold uppercase tracking-[0.22em] sm:text-base">
                <span class="btn-paint" aria-hidden="true"></span>
                <span class="btn-label relative z-[1] inline-flex items-center justify-center gap-3">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l1.9 4.6L18.5 9l-4.6 1.9L12 15l-1.9-4.1L5.5 9l4.6-1.4L12 3Z"></path><path d="M19 14l.8 2 2 .8-2 .8-.8 2-.8-2-2-.8 2-.8.8-2Z"></path></svg>
                  Find My Signature Scent
                </span>
              </button>
            </span>
            <a href="#catalogue" class="btn-ghost inline-flex w-full items-center justify-center gap-2 rounded-full px-7 py-3 text-xs uppercase tracking-[0.2em]">
              Explore the Catalog
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 5v14M5 12l7 7 7-7"></path></svg>
            </a>
          </div>
        </div>

        <!-- right: the bottle carousel (in place of the old glow blob) -->
        <div class="relative fade-in" style="--d:500ms">
          <!-- gender selector — plain caps text, men default -->
          <div id="gender-toggle" class="absolute inset-x-0 -top-7 z-10 flex items-center justify-center gap-7">
            {GENDERS.map((g) => (
              <button
                class="gender-link text-[0.7rem] uppercase tracking-[0.24em]"
                data-gender={g}
                aria-pressed={g === "men" ? "true" : "false"}
              >
                {g}
              </button>
            ))}
          </div>
          <div id="carousel" class="carousel relative mx-auto h-[26rem] w-full max-w-xl sm:h-[30rem]">
            {
              carousel.map((c, i) => (
                <figure class="cr-item" data-i={i} data-id={c.id} data-group={c.group}>
                  <div class="cr-aura" data-temp={c.temp} />
                  <div class="cr-float relative flex h-60 items-center justify-center sm:h-64">
                    <img
                      src={c.image}
                      alt={`${c.brand} ${c.name} bottle`}
                      class="h-full w-auto object-contain drop-shadow-[0_24px_38px_rgba(0,0,0,0.5)]"
                    />
                  </div>
                  <figcaption class="cr-cap">
                    <span class="cr-group">{c.group}</span>
                    <span class="cr-brand">{c.brand}</span>
                    <span class="cr-name">{c.name}</span>
                  </figcaption>
                </figure>
              ))
            }
          </div>

          <!-- slider controls -->
          <div class="mt-4 flex items-center justify-center gap-4">
            <button id="cr-prev" class="cr-arrow" aria-label="Previous bottle">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"></path></svg>
            </button>
            <div id="cr-dots" class="flex items-center justify-center gap-2"></div>
            <button id="cr-next" class="cr-arrow" aria-label="Next bottle">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"></path></svg>
            </button>
          </div>
          <p class="mt-2 text-center text-[0.6rem] uppercase tracking-[0.2em]" style="color:var(--text-faint)">Drag · or tap a bottle to view it</p>
        </div>
      </div>
    </section>

    <!-- ───────────────────── Marquee of houses ─────────────────── -->
    <div class="overflow-hidden border-y py-5" style="border-color:var(--border)">
      <div class="marquee-track flex w-max items-center gap-12 whitespace-nowrap">
        {[...houses, ...houses].map((h) => (
          <span class="font-display text-lg" style="color:var(--text-faint)">
            {h} <span style="color:var(--accent)">·</span>
          </span>
        ))}
      </div>
    </div>

    <!-- ───────────────────────── Catalogue ───────────────────────── -->
    <section id="catalogue" class="px-6 py-16 md:px-10 md:py-24">
      <div class="mx-auto max-w-7xl">
        <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between" data-reveal>
          <div>
            <p class="eyebrow">The Catalogue</p>
            <h2 class="font-display mt-3 text-4xl font-light tracking-tight md:text-6xl">Pick your category.</h2>
          </div>
        </div>

        <!-- seasonal category cards -->
        <div id="big-nav" class="mt-8 grid grid-cols-2 gap-3 md:grid-cols-4 md:gap-4" data-reveal>
          {bigNav.map((b) => (
            <button
              class="catcard group relative overflow-hidden rounded-2xl border p-5 text-left md:p-6"
              data-mood={b.value}
              aria-pressed="false"
              style={`--glow:${b.glow}`}
            >
              <span class="catcard-glow" />
              <span class="relative flex items-center justify-between">
                <span class="catcard-icon" set:html={b.value === "summer" ? `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>` : b.value === "winter" ? `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M2 12h20M5 5l14 14M19 5 5 19M12 4l-2 2 2 2 2-2-2-2M12 16l-2 2 2 2 2-2-2-2M4 12l2-2 2 2-2 2-2-2M16 12l2-2 2 2-2 2-2-2"/></svg>` : b.value === "day" ? `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M17 18a5 5 0 0 0-10 0M12 2v7M4.2 10.2l1.4 1.4M1 18h2M21 18h2M18.4 11.6l1.4-1.4M23 22H1M8 6l4-4 4 4"/></svg>` : `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"/></svg>`} />
                <span class="text-[0.62rem] uppercase tracking-[0.16em]" style="color:var(--text-faint)">{b.n} scents</span>
              </span>
              <span class="relative mt-10 block md:mt-14">
                <span class="block text-[0.6rem] uppercase tracking-[0.22em]" style="color:var(--text-muted)">{b.sub}</span>
                <span class="font-display block text-3xl leading-none tracking-tight md:text-4xl">{b.label}</span>
              </span>
            </button>
          ))}
        </div>

        <!-- sidebar + grid -->
        <div class="mt-10 grid gap-8 lg:grid-cols-[250px_1fr]">
          <!-- sidebar -->
          <aside class="h-max lg:sticky lg:top-24">
            <div class="rounded-2xl border p-6" style="border-color:var(--border);background:var(--surface)">
              <div class="flex items-center justify-between">
                <p class="text-sm font-semibold uppercase tracking-[0.16em]">Filters</p>
                <button id="reset-filters" class="text-[0.65rem] uppercase tracking-[0.14em]" style="color:var(--accent)">Reset</button>
              </div>

              <div class="filter-group mt-6">
                <p class="eyebrow mb-3">Gender</p>
                <div class="flex flex-wrap gap-2">
                  <button class="chip rounded-full px-3.5 py-1.5 text-xs" data-group="gender" data-value="men" aria-pressed="true">Men</button>
                  <button class="chip rounded-full px-3.5 py-1.5 text-xs" data-group="gender" data-value="women" aria-pressed="false">Women</button>
                  <button class="chip rounded-full px-3.5 py-1.5 text-xs" data-group="gender" data-value="unisex" aria-pressed="false">Unisex</button>
                </div>
              </div>

              <div class="filter-group">
                <p class="eyebrow mb-3">Price Tier</p>
                <div class="flex flex-wrap gap-2">
                  <button class="chip rounded-full px-3.5 py-1.5 text-xs" data-group="price" data-value="budget" aria-pressed="false">Budget</button>
                  <button class="chip rounded-full px-3.5 py-1.5 text-xs" data-group="price" data-value="premium" aria-pressed="false">Premium</button>
                </div>
              </div>

              <div class="filter-group">
                <p class="eyebrow mb-3">House Type</p>
                <div class="flex flex-wrap gap-2">
                  <button class="chip rounded-full px-3.5 py-1.5 text-xs" data-group="house" data-value="designer" aria-pressed="false">Designer</button>
                  <button class="chip rounded-full px-3.5 py-1.5 text-xs" data-group="house" data-value="niche" aria-pressed="false">Niche</button>
                </div>
              </div>

              <div class="filter-group">
                <p class="eyebrow mb-3">Sillage</p>
                <div class="flex flex-wrap gap-2">
                  <button class="chip rounded-full px-3.5 py-1.5 text-xs" data-group="sillage" data-value="Low" aria-pressed="false">Low</button>
                  <button class="chip rounded-full px-3.5 py-1.5 text-xs" data-group="sillage" data-value="High" aria-pressed="false">High</button>
                </div>
              </div>

              <div class="filter-group">
                <p class="eyebrow mb-3">Projection</p>
                <div class="flex flex-wrap gap-2">
                  <button class="chip rounded-full px-3.5 py-1.5 text-xs" data-group="projection" data-value="Low" aria-pressed="false">Low</button>
                  <button class="chip rounded-full px-3.5 py-1.5 text-xs" data-group="projection" data-value="High" aria-pressed="false">High</button>
                </div>
              </div>

              <div class="filter-group">
                <p class="eyebrow mb-3">Olfactory Profile</p>
                <div class="flex flex-wrap gap-2">
                  {FAMILIES.map((fam) => (
                    <button class="chip rounded-full px-3.5 py-1.5 text-xs" data-group="family" data-value={fam} aria-pressed="false">{fam}</button>
                  ))}
                </div>
              </div>
            </div>
          </aside>

          <!-- grid -->
          <div>
            <p id="result-count" class="mb-5 text-xs uppercase tracking-[0.2em]" style="color:var(--text-faint)">Showing {total} of {total}</p>
            <div id="grid" class="grid grid-cols-1 gap-5 sm:grid-cols-2 xl:grid-cols-3">
              {fragrances.map((f, i) => <FragranceCard f={f} index={i} />)}
            </div>
            <p id="empty-state" class="hidden py-20 text-center font-display text-2xl" style="color:var(--text-faint)">
              Nothing matches that mood. Try fewer filters.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ───────────────────────── About ───────────────────────── -->
    <section id="about" class="border-t px-6 py-24 md:px-10" style="border-color:var(--border)">
      <div class="mx-auto grid max-w-7xl gap-12 md:grid-cols-2 md:items-center" data-reveal>
        <h2 class="font-display text-3xl font-light leading-tight tracking-tight md:text-5xl">
          Scent is the most under-rated part of getting dressed.
        </h2>
        <div class="space-y-5 text-base" style="color:var(--text-muted)">
          <p>Fragrandise is an editorial guide, not a store. We taste-test the hype so you don't have to — pairing each bottle with the season, the hour, the house, and the budget it actually belongs to.</p>
          <p>Every recommendation links to a vetted decant partner, so you can try before you commit to a full bottle. No fluff, just the edit.</p>
        </div>
      </div>
    </section>
  </main>

  <!-- ───────────────────────── Footer ───────────────────────── -->
  <footer id="footer" class="border-t px-6 pb-10 pt-20 md:px-10" style="border-color:var(--border)">
    <div class="mx-auto max-w-7xl">
      <div class="grid gap-12 md:grid-cols-2">
        <div>
          <h3 class="font-display text-3xl tracking-tight">FRAGRANDISE</h3>
          <p class="mt-4 max-w-sm text-sm" style="color:var(--text-muted)">Join the list for monthly drops, blind-buy verdicts, and seasonal edits — straight to your inbox.</p>
          <form id="newsletter" class="mt-6 flex max-w-md items-center gap-2 rounded-full border p-1.5" style="border-color:var(--border-strong)">
            <input type="email" required placeholder="you@scent.com" class="w-full bg-transparent px-4 py-2 text-sm outline-none" style="color:var(--text)" />
            <button type="submit" class="btn-accent shrink-0 rounded-full px-5 py-2 text-xs uppercase tracking-[0.18em]">Join the list</button>
          </form>
        </div>
        <div class="grid grid-cols-2 gap-8 md:justify-items-end">
          <div>
            <p class="eyebrow mb-4">Explore</p>
            <ul class="space-y-2 text-sm" style="color:var(--text-muted)">
              <li><a href="#catalogue" class="link-underline">Categories</a></li>
              <li><a href="#about" class="link-underline">About</a></li>
              <li><a href="#footer" class="link-underline">Affiliates</a></li>
            </ul>
          </div>
          <div>
            <p class="eyebrow mb-4">Legal</p>
            <ul class="space-y-2 text-sm" style="color:var(--text-muted)">
              <li><a href="#" class="link-underline">Privacy Policy</a></li>
              <li><a href="#" class="link-underline">Terms of Service</a></li>
              <li><a href="#" class="link-underline">Contact</a></li>
            </ul>
          </div>
        </div>
      </div>
      <div class="mt-16 flex flex-col gap-3 border-t pt-6 text-xs sm:flex-row sm:items-center sm:justify-between" style="border-color:var(--border);color:var(--text-faint)">
        <p>© 2026 Fragrandise. All rights reserved.</p>
        <p>A Guide for Smelling Good. Fashion Blended.</p>
      </div>
    </div>
  </footer>

  <!-- ───────────────────────── Drawer / modal ───────────────────────── -->
  <div id="drawer" class="fixed inset-0 z-[70]">
    <div class="scrim absolute inset-0" style="background:rgba(0,0,0,0.6)" data-close-drawer></div>
    <aside class="panel absolute right-0 top-0 flex h-full w-full max-w-md flex-col overflow-y-auto sm:max-w-lg" style="background:var(--bg-soft)">
      <div class="flex items-center justify-between px-7 pt-7">
        <p class="eyebrow" id="d-meta"></p>
        <button data-close-drawer aria-label="Close" class="grid h-9 w-9 place-items-center rounded-full border" style="border-color:var(--border-strong);color:var(--text)">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"></path></svg>
        </button>
      </div>
      <div id="d-stage" class="relative mx-7 mt-4 flex h-72 items-center justify-center rounded-2xl" style="background:var(--surface)">
        <div id="d-glow" class="absolute inset-0 m-auto h-48 w-48 rounded-full" style="filter:blur(48px);opacity:0.4"></div>
        <div id="d-bottle" class="relative flex h-60 items-center justify-center"></div>
      </div>
      <div class="px-7 py-7">
        <h3 class="text-3xl font-bold tracking-tight" id="d-brand"></h3>
        <p class="font-display mt-1 text-xl font-light" id="d-name" style="color:var(--text-muted)"></p>
        <p class="mt-4 text-base leading-relaxed" id="d-desc" style="color:var(--text-muted)"></p>

        <div class="mt-6 flex flex-wrap gap-2" id="d-tags"></div>

        <p class="eyebrow mt-8 mb-3">Performance</p>
        <div class="grid grid-cols-2 gap-3">
          <div class="rounded-xl border p-3.5" style="border-color:var(--border);background:var(--surface)">
            <p class="text-[0.58rem] uppercase tracking-[0.18em]" style="color:var(--text-faint)">Sillage</p>
            <p class="mt-1 flex items-center gap-2 text-sm font-semibold"><span id="d-sillage-dot" class="inline-block h-2 w-2 rounded-full"></span><span id="d-sillage"></span></p>
          </div>
          <div class="rounded-xl border p-3.5" style="border-color:var(--border);background:var(--surface)">
            <p class="text-[0.58rem] uppercase tracking-[0.18em]" style="color:var(--text-faint)">Projection</p>
            <p class="mt-1 flex items-center gap-2 text-sm font-semibold"><span id="d-projection-dot" class="inline-block h-2 w-2 rounded-full"></span><span id="d-projection"></span></p>
          </div>
        </div>

        <p class="eyebrow mt-8 mb-3">Note Pyramid</p>
        <div class="space-y-3" id="d-notes"></div>

        <p class="eyebrow mt-8 mb-3">Where to Buy</p>
        <div class="flex flex-col gap-3">
          <a id="d-amazon" href="#" target="_blank" rel="noopener" class="btn-accent flex items-center justify-between rounded-xl px-5 py-4 text-sm">
            <span class="font-medium">Find it on Amazon</span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M7 17 17 7M7 7h10v10"></path></svg>
          </a>
        </div>
      </div>
    </aside>
  </div>

  <!-- ───────────────────────── Dictionary drawer ───────────────────────── -->
  <div id="dict-drawer" class="fixed inset-0 z-50">
    <div class="scrim absolute inset-0" style="background:rgba(0,0,0,0.6)" data-close-dict></div>
    <aside class="dict-panel absolute left-0 top-0 flex h-full w-full max-w-md flex-col overflow-y-auto sm:max-w-lg" style="background:var(--bg-soft)">
      <div class="flex items-center justify-between px-7 pt-7">
        <div>
          <p class="eyebrow">The Fragrance</p>
          <h3 class="font-display text-3xl font-light tracking-tight">Dictionary</h3>
        </div>
        <button data-close-dict aria-label="Close" class="grid h-9 w-9 place-items-center rounded-full border" style="border-color:var(--border-strong);color:var(--text)">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"></path></svg>
        </button>
      </div>
      <p class="px-7 pt-4 text-sm" style="color:var(--text-muted)">New to fragrance? Here's the lingo, in plain English.</p>
      <div class="mt-4 flex flex-col gap-3 px-7 pb-10">
        {[
          { term: "Sillage", def: "The invisible scent trail you leave behind when you walk away." },
          { term: "Projection", def: "How far the scent pushes off your skin and into the room." },
          { term: "Designer", def: "Perfumes made by mainstream fashion / clothing houses (e.g. Dior, Chanel, Versace)." },
          { term: "Niche", def: "Perfumes made by specialised houses that only create fragrances (e.g. Creed, Xerjoff, Amouage)." },
          { term: "Blind Buy", def: "Buying a full bottle of perfume without ever smelling it first." },
          { term: "Olfactory Notes", def: "The ingredients that make up the scent. Top = first 15 minutes · Middle / Heart = the core scent · Base = the heavy notes that last all day." },
        ].map((d) => (
          <div class="dict-card rounded-2xl border p-5" style="border-color:var(--border);background:var(--surface)">
            <p class="font-display text-xl tracking-tight" style="color:var(--accent)">{d.term}</p>
            <p class="mt-1.5 text-sm leading-relaxed" style="color:var(--text-muted)">{d.def}</p>
          </div>
        ))}
      </div>
    </aside>
  </div>

  <!-- ───────────────────────── Quiz overlay ───────────────────────── -->
  <div id="quiz" class="fixed inset-0 z-[60]">
    <div class="quiz-scrim absolute inset-0" style="background:color-mix(in srgb, var(--bg) 88%, transparent);backdrop-filter:blur(8px)"></div>
    <div class="quiz-shell absolute inset-0 flex flex-col">
      <!-- top bar -->
      <div class="mx-auto flex w-full max-w-3xl items-center justify-between px-6 pt-7 md:px-10">
        <span class="font-display text-lg tracking-tight">Signature Scent Finder</span>
        <button id="quiz-close" aria-label="Close quiz" class="grid h-9 w-9 place-items-center rounded-full border" style="border-color:var(--border-strong);color:var(--text)">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"></path></svg>
        </button>
      </div>
      <!-- progress -->
      <div class="mx-auto mt-5 w-full max-w-3xl px-6 md:px-10">
        <div class="flex items-center justify-between text-[0.62rem] uppercase tracking-[0.2em]" style="color:var(--text-faint)">
          <span id="quiz-phase">The Canvas</span>
          <span id="quiz-counter">1 / 20</span>
        </div>
        <div class="mt-2 h-1 w-full overflow-hidden rounded-full" style="background:var(--border)">
          <div id="quiz-progress" class="h-full rounded-full" style="width:5%;background:var(--accent);transition:width .5s cubic-bezier(.16,1,.3,1)"></div>
        </div>
      </div>

      <!-- question stage -->
      <div class="quiz-scroll flex-1 overflow-y-auto">
        <div id="quiz-stage" class="mx-auto flex w-full max-w-3xl flex-col px-6 py-10 md:px-10"></div>
      </div>
    </div>
  </div>

  <script type="application/json" id="quiz-frag-data" set:html={JSON.stringify(quizFragrances)}></script>
  <script type="application/json" id="carousel-data" set:html={JSON.stringify(carouselByGender)}></script>
</Layout>

<script>
  // ─── Theme toggle ───────────────────────────────────────────────────────
  const root = document.documentElement;
  const toggle = document.getElementById("theme-toggle");
  const moon = document.getElementById("icon-moon");
  const sun = document.getElementById("icon-sun");
  function syncIcons() {
    const light = root.getAttribute("data-theme") === "light";
    if (moon) moon.style.display = light ? "none" : "block";
    if (sun) sun.style.display = light ? "block" : "none";
  }
  syncIcons();
  toggle?.addEventListener("click", () => {
    const next = root.getAttribute("data-theme") === "light" ? "dark" : "light";
    root.setAttribute("data-theme", next);
    try { localStorage.setItem("fr-theme", next); } catch (e) {}
    syncIcons();
  });

  // ─── Header on scroll ───────────────────────────────────────────────────
  const header = document.getElementById("site-header");
  const onScroll = () => {
    if (!header) return;
    if (window.scrollY > 24) {
      header.style.background = "color-mix(in srgb, var(--bg) 82%, transparent)";
      header.style.backdropFilter = "blur(18px)";
      header.style.borderBottom = "1px solid var(--border)";
    } else {
      header.style.background = "transparent";
      header.style.backdropFilter = "none";
      header.style.borderBottom = "1px solid transparent";
    }
  };
  onScroll();
  window.addEventListener("scroll", onScroll, { passive: true });

  // ─── Parallax ───────────────────────────────────────────────────────────
  const parallaxEls = Array.from(document.querySelectorAll<HTMLElement>("[data-parallax]"));
  let ticking = false;
  window.addEventListener("scroll", () => {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(() => {
      const y = window.scrollY;
      for (const el of parallaxEls) {
        const speed = parseFloat(el.dataset.parallax || "0");
        el.style.transform = `translateY(${y * speed}px)`;
      }
      ticking = false;
    });
  }, { passive: true });

  // ─── Reveal on scroll ───────────────────────────────────────────────────
  const io = new IntersectionObserver((entries) => {
    for (const e of entries) {
      if (e.isIntersecting) { e.target.classList.add("in"); io.unobserve(e.target); }
    }
  }, { threshold: 0.12, rootMargin: "0px 0px -8% 0px" });
  document.querySelectorAll("[data-reveal]").forEach((el) => io.observe(el));

  // ─── Carousel (draggable slider + tap to view in catalogue) ─────────────
  // Assigned inside the carousel block; called by the shared setGender().
  let repopulateCarousel: ((g: string) => void) | null = null;
  const carouselEl = document.getElementById("carousel");
  if (carouselEl) {
    const crItems = Array.from(carouselEl.querySelectorAll<HTMLElement>(".cr-item"));
    const n = crItems.length;
    let pos = 0; // fractional position; round() = active bottle
    let crTimer: number | undefined;
    let crPause: number | undefined;

    const dotsWrap = document.getElementById("cr-dots");
    crItems.forEach((_, i) => {
      const d = document.createElement("button");
      d.className = "cr-dot";
      d.setAttribute("aria-label", `Go to bottle ${i + 1}`);
      d.addEventListener("click", () => { pos = i; layout(); restart(4000); });
      dotsWrap?.appendChild(d);
    });
    const dots = Array.from(dotsWrap?.children || []) as HTMLElement[];

    const spacingOf = () => {
      const cw = carouselEl.clientWidth || 480;
      return Math.max(86, Math.min(150, cw * 0.26));
    };
    const activeIndex = () => ((Math.round(pos) % n) + n) % n;

    function layout() {
      const spacing = spacingOf();
      const ai = activeIndex();
      crItems.forEach((el, i) => {
        let off = i - pos;
        while (off > n / 2) off -= n;
        while (off < -n / 2) off += n;
        const a = Math.abs(off);
        el.style.transform = `translate(-50%,-50%) translateX(${off * spacing}px) scale(${Math.max(0.55, 1.08 - a * 0.16)})`;
        el.style.opacity = String(a > 2.6 ? 0 : 1 - a * 0.26);
        el.style.zIndex = String(100 - Math.round(a));
        el.style.filter = a < 0.5 ? "none" : `blur(${a * 0.7}px)`;
        el.classList.toggle("is-active", i === ai);
        dots[i]?.classList.toggle("active", i === ai);
      });
    }

    // restart(delay): wait `delay` ms (e.g. after a manual nudge) before
    // resuming the 1.5s auto-rotation, so user clicks don't fight the cycle.
    function restart(delay = 0) {
      if (crTimer) { clearInterval(crTimer); crTimer = undefined; }
      if (crPause) { clearTimeout(crPause); crPause = undefined; }
      const begin = () => { crTimer = window.setInterval(() => { pos = Math.round(pos) + 1; layout(); }, 1500); };
      if (delay > 0) crPause = window.setTimeout(begin, delay);
      else begin();
    }
    function stop() {
      if (crTimer) { clearInterval(crTimer); crTimer = undefined; }
      if (crPause) { clearTimeout(crPause); crPause = undefined; }
    }

    document.getElementById("cr-prev")?.addEventListener("click", () => { pos = Math.round(pos) - 1; layout(); restart(4000); });
    document.getElementById("cr-next")?.addEventListener("click", () => { pos = Math.round(pos) + 1; layout(); restart(4000); });

    // open the matching fragrance in the catalogue
    function openFromCarousel(id: string | null) {
      if (!id) return;
      const btn = document.querySelector<HTMLElement>(`#grid [data-open-drawer][data-id="${id}"]`);
      if (!btn) return;
      const wrap = btn.closest(".card-wrap");
      wrap?.classList.remove("hidden-card");
      wrap?.scrollIntoView({ behavior: "smooth", block: "center" });
      openDrawer(btn);
    }

    // drag to slide (window-level so native clicks on bottles still fire)
    let dragging = false, startX = 0, startY = 0, startPos = 0, moved = 0, spc = 120;
    carouselEl.addEventListener("pointerdown", (e) => {
      dragging = true; startX = e.clientX; startY = e.clientY; startPos = pos; moved = 0; spc = spacingOf();
      stop();
      carouselEl.classList.add("dragging");
    });
    window.addEventListener("pointermove", (e) => {
      if (!dragging) return;
      const dx = e.clientX - startX;
      moved = Math.max(moved, Math.abs(dx), Math.abs(e.clientY - startY));
      pos = startPos - dx / spc;
      layout();
    });
    function endDrag(e?: PointerEvent) {
      if (!dragging) return;
      dragging = false;
      carouselEl.classList.remove("dragging");
      // a tap (no real drag) → open that bottle's details
      if (moved <= 6 && e) {
        const el = (document.elementFromPoint(e.clientX, e.clientY) as HTMLElement | null)?.closest(".cr-item");
        if (el) openFromCarousel(el.getAttribute("data-id"));
      }
      pos = Math.round(pos);
      layout();
      restart(4000);
    }
    window.addEventListener("pointerup", endDrag);
    window.addEventListener("pointercancel", () => endDrag());

    // also handle plain clicks (mouse) as a fallback
    crItems.forEach((el) => {
      el.addEventListener("click", () => {
        if (moved > 6) return;
        openFromCarousel(el.getAttribute("data-id"));
      });
    });

    carouselEl.addEventListener("pointerenter", () => { if (!dragging) stop(); });
    carouselEl.addEventListener("pointerleave", () => { if (!dragging) restart(); });
    window.addEventListener("resize", layout);
    layout();
    restart();

    // ── gender toggle: swap the 12 bottles + filter the catalogue grid ──
    const carouselData = JSON.parse(document.getElementById("carousel-data")?.textContent || "{}");
    function populateCarousel(gender: string) {
      const items = carouselData[gender] || [];
      crItems.forEach((el, i) => {
        const d = items[i];
        if (!d) { el.style.display = "none"; return; }
        el.style.display = "";
        el.setAttribute("data-id", d.id);
        el.setAttribute("data-group", d.group);
        el.querySelector(".cr-aura")?.setAttribute("data-temp", d.temp);
        const img = el.querySelector("img");
        if (img) { (img as HTMLImageElement).src = d.image; img.setAttribute("alt", `${d.brand} ${d.name} bottle`); }
        const setTxt = (sel: string, t: string) => { const n = el.querySelector(sel); if (n) n.textContent = t; };
        setTxt(".cr-group", d.group); setTxt(".cr-brand", d.brand); setTxt(".cr-name", d.name);
      });
      pos = 0; layout(); restart(4000);
    }
    repopulateCarousel = populateCarousel;
  }

  // ─── Filtering ──────────────────────────────────────────────────────────
  const cards = Array.from(document.querySelectorAll<HTMLElement>(".card-wrap"));
  const countEl = document.getElementById("result-count");
  const emptyEl = document.getElementById("empty-state");
  const total = cards.length;

  const active = {
    gender: new Set<string>(["men"]), // multi-select grid filter; men preselected
    mood: new Set<string>(),
    price: new Set<string>(),
    house: new Set<string>(),
    sillage: new Set<string>(),
    projection: new Set<string>(),
    family: new Set<string>(),
  };

  function applyFilters() {
    let shown = 0;
    for (const card of cards) {
      const season = card.dataset.season || "";
      const times = (card.dataset.times || "").split(" ");
      const price = card.dataset.price || "";
      const house = card.dataset.house || "";
      const gender = card.dataset.gender || "men";
      const sillage = card.dataset.sillage || "";
      const projection = card.dataset.projection || "";
      const families = (card.dataset.families || "").split(" ");

      const okGender = active.gender.size === 0 || active.gender.has(gender);
      const okMood = active.mood.size === 0 ||
        [...active.mood].some((m) => season === m || times.includes(m));
      const okPrice = active.price.size === 0 || active.price.has(price);
      const okHouse = active.house.size === 0 || active.house.has(house);
      const okSillage = active.sillage.size === 0 || active.sillage.has(sillage);
      const okProjection = active.projection.size === 0 || active.projection.has(projection);
      const okFamily = active.family.size === 0 ||
        families.some((fam) => active.family.has(fam));

      const visible = okGender && okMood && okPrice && okHouse && okSillage && okProjection && okFamily;
      card.classList.toggle("hidden-card", !visible);
      if (visible) shown++;
    }
    if (countEl) countEl.textContent = `Showing ${shown} of ${total}`;
    if (emptyEl) emptyEl.classList.toggle("hidden", shown !== 0);
  }
  applyFilters(); // enforce the default (men) gender view on load

  // Carousel gender toggle: single-select, controls the carousel bottles only.
  document.querySelectorAll<HTMLButtonElement>(".gender-link[data-gender]").forEach((btn) =>
    btn.addEventListener("click", () => {
      const g = btn.dataset.gender || "men";
      document.querySelectorAll<HTMLButtonElement>(".gender-link[data-gender]").forEach((b) =>
        b.setAttribute("aria-pressed", String(b.dataset.gender === g)));
      repopulateCarousel?.(g);
    }));

  // sidebar chips — multi-select (gender / price / house / family alike)
  document.querySelectorAll<HTMLButtonElement>(".chip[data-group]").forEach((chip) => {
    chip.addEventListener("click", () => {
      const group = chip.dataset.group as "gender" | "price" | "house" | "sillage" | "projection" | "family";
      const value = chip.dataset.value || "";
      const set = active[group];
      if (set.has(value)) { set.delete(value); chip.setAttribute("aria-pressed", "false"); }
      else { set.add(value); chip.setAttribute("aria-pressed", "true"); }
      applyFilters();
    });
  });

  // seasonal category cards
  document.querySelectorAll<HTMLButtonElement>(".catcard[data-mood]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const value = btn.dataset.mood || "";
      if (active.mood.has(value)) { active.mood.delete(value); btn.setAttribute("aria-pressed", "false"); }
      else { active.mood.add(value); btn.setAttribute("aria-pressed", "true"); }
      applyFilters();
    });
  });

  document.getElementById("reset-filters")?.addEventListener("click", () => {
    active.gender.clear(); active.mood.clear(); active.price.clear(); active.house.clear();
    active.sillage.clear(); active.projection.clear(); active.family.clear();
    document.querySelectorAll("[aria-pressed]").forEach((c) => {
      const el = c as HTMLElement;
      if (el.id === "theme-toggle" || el.classList.contains("gender-link")) return;
      el.setAttribute("aria-pressed", "false");
    });
    document.querySelectorAll(".nav-link[data-nav-mood]").forEach((n) => n.classList.remove("nav-active"));
    applyFilters();
  });

  // ─── Drawer ─────────────────────────────────────────────────────────────
  const drawer = document.getElementById("drawer");
  const dBottle = document.getElementById("d-bottle");
  const dGlow = document.getElementById("d-glow");

  const tierIcon: Record<string, string> = {
    Top: `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v6"/><path d="M12 9c-3 0-5 2-5 5a5 5 0 0 0 10 0c0-3-2-5-5-5Z"/><path d="M9 4c1.5.5 3 .5 3 2"/></svg>`,
    Heart: `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="2.5"/><path d="M12 9.5c0-2.5 1-4.5 0-6.5-1 2 0 4 0 6.5Z"/><path d="M12 14.5c0 2.5-1 4.5 0 6.5 1-2 0-4 0-6.5Z"/><path d="M9.5 12c-2.5 0-4.5-1-6.5 0 2 1 4 0 6.5 0Z"/><path d="M14.5 12c2.5 0 4.5 1 6.5 0-2-1-4 0-6.5 0Z"/></svg>`,
    Base: `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 4 3 9l9 5 9-5-9-5Z"/><path d="M3 14l9 5 9-5"/></svg>`,
  };

  function chipEl(text: string) {
    const s = document.createElement("span");
    s.className = "rounded-full border px-3 py-1 text-xs capitalize";
    s.style.borderColor = "var(--border-strong)";
    s.style.color = "var(--text-muted)";
    s.textContent = text;
    return s;
  }

  function noteRow(tier: string, notes: string) {
    if (!notes) return "";
    return `<div class="flex items-start gap-2.5">
      <span class="mt-0.5 shrink-0" style="color:var(--accent)">${tierIcon[tier] || ""}</span>
      <div><span class="mr-2 text-[0.62rem] font-semibold uppercase tracking-[0.14em]" style="color:var(--text-faint)">${tier}</span><span class="text-sm" style="color:var(--text-muted)">${notes}</span></div>
    </div>`;
  }

  function bottleSVG(from: string, to: string, ini: string) {
    return `<svg viewBox="0 0 200 280" class="h-full w-full" xmlns="http://www.w3.org/2000/svg"><defs><linearGradient id="dg" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="${from}"/><stop offset="100%" stop-color="${to}"/></linearGradient><linearGradient id="ds" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#fff" stop-opacity="0.55"/><stop offset="35%" stop-color="#fff" stop-opacity="0.08"/><stop offset="100%" stop-color="#fff" stop-opacity="0"/></linearGradient></defs><rect x="82" y="14" width="36" height="34" rx="4" fill="${to}"/><rect x="86" y="46" width="28" height="14" rx="2" fill="${to}" opacity="0.9"/><rect x="48" y="58" width="104" height="200" rx="18" fill="url(#dg)"/><rect x="58" y="68" width="30" height="180" rx="14" fill="url(#ds)"/><text x="100" y="172" text-anchor="middle" font-family="Fraunces, serif" font-size="34" font-weight="500" fill="#fff" fill-opacity="0.92">${ini}</text></svg>`;
  }

  function openDrawer(btn: HTMLElement) {
    const d = btn.dataset;
    const set = (id: string, val: string) => { const el = document.getElementById(id); if (el) el.textContent = val; };
    set("d-meta", `${d.house || ""} · ${d.price || ""}`);
    set("d-brand", d.brand || "");
    set("d-name", d.name || "");
    set("d-desc", d.desc || "");

    const from = d.from || "#888", to = d.to || "#444";
    if (dBottle) {
      const src = d.image || "";
      dBottle.innerHTML = src
        ? `<img src="${src}" alt="${(d.brand || "") + " " + (d.name || "")} bottle" class="h-full w-auto object-contain drop-shadow-[0_24px_40px_rgba(0,0,0,0.5)]" />`
        : bottleSVG(from, to, d.initials || "");
    }
    if (dGlow) dGlow.style.background = `radial-gradient(circle, ${from}, transparent 70%)`;

    const tags = document.getElementById("d-tags");
    if (tags) {
      tags.innerHTML = "";
      tags.appendChild(chipEl(d.season || ""));
      (d.times || "").split(" ").filter(Boolean).forEach((t) => tags.appendChild(chipEl(t)));
      (d.families || "").split(", ").filter(Boolean).forEach((f) => tags.appendChild(chipEl(f)));
    }

    const notes = document.getElementById("d-notes");
    if (notes) {
      notes.innerHTML = noteRow("Top", d.top || "") + noteRow("Heart", d.mid || "") + noteRow("Base", d.base || "");
    }

    // performance (sillage + projection) with a colour-coded strength dot
    const perfDot = (level: string) => (level === "High" ? "var(--accent)" : "var(--text-faint)");
    const setPerf = (txtId: string, dotId: string, level: string) => {
      const t = document.getElementById(txtId); if (t) t.textContent = level || "—";
      const dot = document.getElementById(dotId); if (dot) (dot as HTMLElement).style.background = perfDot(level);
    };
    setPerf("d-sillage", "d-sillage-dot", d.sillage || "");
    setPerf("d-projection", "d-projection-dot", d.projection || "");

    const amazon = document.getElementById("d-amazon") as HTMLAnchorElement | null;
    if (amazon) amazon.href = d.amazon || "#";

    drawer?.classList.add("open");
    document.body.style.overflow = "hidden";
  }

  function closeDrawer() {
    drawer?.classList.remove("open");
    // If the quiz results are still open underneath, keep the page locked.
    document.body.style.overflow = document.getElementById("quiz")?.classList.contains("open") ? "hidden" : "";
  }

  document.querySelectorAll<HTMLElement>("[data-open-drawer]").forEach((btn) => {
    btn.addEventListener("click", (e) => {
      if ((e.target as HTMLElement).closest("[data-stop]")) return;
      openDrawer(btn);
    });
  });
  document.querySelectorAll("[data-close-drawer]").forEach((el) => el.addEventListener("click", closeDrawer));
  document.addEventListener("keydown", (e) => { if (e.key === "Escape") closeDrawer(); });

  // ─── Newsletter (demo) ──────────────────────────────────────────────────
  document.getElementById("newsletter")?.addEventListener("submit", (e) => {
    e.preventDefault();
    const form = e.currentTarget as HTMLFormElement;
    const btn = form.querySelector("button");
    if (btn) btn.textContent = "You're on the list ✓";
    form.reset();
  });

  // ─── Dictionary drawer ──────────────────────────────────────────────────
  const dict = document.getElementById("dict-drawer");
  function openDict() { dict?.classList.add("open"); document.body.style.overflow = "hidden"; }
  function closeDict() { dict?.classList.remove("open"); document.body.style.overflow = ""; }
  document.getElementById("open-dictionary")?.addEventListener("click", openDict);
  document.querySelectorAll("[data-close-dict]").forEach((el) => el.addEventListener("click", closeDict));

  // ─── Nav category links → exclusive mood filter (one at a time) ─────────
  document.querySelectorAll<HTMLButtonElement>(".nav-link[data-nav-mood]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const mood = btn.dataset.navMood || "";
      const alreadyOnly = active.mood.size === 1 && active.mood.has(mood);
      active.mood.clear();
      if (!alreadyOnly) active.mood.add(mood);
      // reflect the single active mood on the seasonal category cards + nav
      document.querySelectorAll<HTMLButtonElement>(".catcard[data-mood]").forEach((c) => {
        c.setAttribute("aria-pressed", String(active.mood.has(c.dataset.mood || "")));
      });
      document.querySelectorAll<HTMLButtonElement>(".nav-link[data-nav-mood]").forEach((n) => {
        n.classList.toggle("nav-active", active.mood.has(n.dataset.navMood || ""));
      });
      applyFilters();
      document.getElementById("catalogue")?.scrollIntoView({ behavior: "smooth", block: "start" });
    });
  });

  // ─── Signature Scent quiz — deterministic scoring engine ────────────────
  type QFrag = {
    id: string; brand: string; name: string; image: string;
    season: "summer" | "winter"; times: ("day" | "night")[];
    houseType: "niche" | "designer"; priceTier: "premium" | "budget";
    gender: "men" | "women" | "unisex";
    families: string[]; accent: [string, string];
  };
  type Eff = Record<string, number>;
  type QOption = { label: string; effects: Eff };
  type Question = { phase: string; q: string; options: QOption[] };

  let quizFrags: QFrag[] = [];
  try { quizFrags = JSON.parse(document.getElementById("quiz-frag-data")?.textContent || "[]"); } catch (e) {}

  // Effect keys: summer/winter/day/night/affordable/expensive/designer/niche,
  // "p:<Profile>" for olfactory profiles, "proj:Low|Moderate|High" for projection.
  const QUESTIONS: Question[] = [
    // ── Phase 0 · Who It's For ──
    { phase: "Who It's For", q: "Who are we finding a signature scent for?", options: [
      { label: "Me — I lean toward classic men's fragrances.", effects: { "g:men": 3 } },
      { label: "Me — I lean toward women's fragrances.", effects: { "g:women": 3 } },
      { label: "Surprise me — I love clean, shareable unisex scents.", effects: { "g:unisex": 3 } },
    ]},
    { phase: "Who It's For", q: "Which character do you want your scent to project?", options: [
      { label: "Sharp, bold, and traditionally masculine.", effects: { "g:men": 2 } },
      { label: "Soft, radiant, and traditionally feminine.", effects: { "g:women": 2 } },
      { label: "Modern and androgynous — anyone could wear it.", effects: { "g:unisex": 2 } },
    ]},
    // ── Phase 1 · The Canvas ──
    { phase: "The Canvas", q: "How would you describe your ideal weekend escape?", options: [
      { label: "A sun-drenched coastline or a vibrant open-air café.", effects: { summer: 2, day: 2 } },
      { label: "Cozying up in a wooden cabin or a dimly lit lounge.", effects: { winter: 2, night: 2 } },
      { label: "A brisk morning walk through a botanical garden.", effects: { summer: 2, day: 2 } },
      { label: "A midnight stroll through a bustling, historic city.", effects: { winter: 2, night: 2 } },
    ]},
    { phase: "The Canvas", q: "What season are you shopping for right now?", options: [
      { label: "Crisp, hot, or humid.", effects: { summer: 3 } },
      { label: "Cool, freezing, or sharp.", effects: { winter: 3 } },
      { label: "I need a versatile scent that survives all seasons.", effects: { summer: 1, winter: 1 } },
    ]},
    { phase: "The Canvas", q: "When do you envision wearing this fragrance the most?", options: [
      { label: "Mornings & afternoons — work, brunch, casual outings.", effects: { day: 3 } },
      { label: "Evenings & late nights — dates, events, nightlife.", effects: { night: 3 } },
      { label: "From sunrise to sunset; a true signature scent.", effects: { day: 1, night: 1 } },
    ]},
    { phase: "The Canvas", q: "What kind of setting do you prefer right now?", options: [
      { label: "Bright sunny days, light clothes, and fresh air.", effects: { summer: 2, day: 2 } },
      { label: "Cozy nights, warm jackets, dim lighting, cool air.", effects: { winter: 2, night: 2 } },
    ]},
    // ── Phase 2 · The Investment ──
    { phase: "The Investment", q: "What is your budget for a new perfume?", options: [
      { label: "Budget-friendly — smells expensive, easy on my wallet.", effects: { affordable: 3 } },
      { label: "Premium / luxury — I'll pay for a top-tier bottle.", effects: { expensive: 3 } },
    ]},
    { phase: "The Investment", q: "Which answer makes you feel best when asked what you're wearing?", options: [
      { label: "A recognisable fashion house (Versace, Tom Ford, LV).", effects: { designer: 3 } },
      { label: "An exclusive, artistic house few people know (Xerjoff, Nishane, Amouage).", effects: { niche: 3 } },
      { label: "I don't care about the name — only that it smells incredible.", effects: { designer: 1, niche: 1 } },
    ]},
    { phase: "The Investment", q: "How do you feel about Middle-Eastern alternative houses (Lattafa, Afnan)?", options: [
      { label: "Love them — incredible value and viral power for the price.", effects: { affordable: 2, designer: 1 } },
      { label: "I prefer classic European / Western designer or niche.", effects: { expensive: 1, niche: 1 } },
      { label: "Not so sure — I'm new to fragrances.", effects: {} },
    ]},
    // ── Phase 3 · The Presence ──
    { phase: "The Presence", q: "What's your ultimate goal when entering a room?", options: [
      { label: "A strong trail — people should smell me after I pass.", effects: { "proj:High": 3 } },
      { label: "A quiet, intimate presence — only close hugs notice it.", effects: { "proj:Low": 3 } },
      { label: "A solid arms-length cloud that commands respect.", effects: { "proj:Moderate": 3 } },
      { label: "No preference — surprise me.", effects: {} },
    ]},
    { phase: "The Presence", q: "How long do you need this fragrance to last?", options: [
      { label: "Workhorse longevity (8+ hrs) — survives a full day or night.", effects: { "proj:High": 2, winter: 1, "p:Gourmand": 1 } },
      { label: "Casual longevity (4–6 hrs) — I don't mind reapplying.", effects: { "proj:Low": 2, summer: 1, "p:Fresh": 1 } },
    ]},
    { phase: "The Presence", q: "How do you react to very heavy, sweet, or smoky scents?", options: [
      { label: "I love them — the louder and more complex, the better.", effects: { winter: 2, "p:Gourmand": 1, "p:Woody": 1 } },
      { label: "They give me a headache — I want clean, airy, refreshing.", effects: { summer: 2, "p:Fresh": 1, "p:Citrus": 1 } },
    ]},
    // ── Phase 4 · Olfactory Archetypes ──
    { phase: "Olfactory Archetypes", q: "Which drink are you ordering at a luxury lounge?", options: [
      { label: "An icy mojito or G&T with fresh lime and crushed mint.", effects: { "p:Citrus": 2, "p:Fresh": 1 } },
      { label: "A warm espresso or a glass of aged cognac / whiskey.", effects: { "p:Gourmand": 2, "p:Sweet": 1 } },
      { label: "A cold, sophisticated iced oolong or Earl Grey.", effects: { "p:Fresh": 1, "p:Spicy": 1 } },
    ]},
    { phase: "Olfactory Archetypes", q: "Where will you wear this fragrance the most?", options: [
      { label: "A beach day or poolside hangout.", effects: { summer: 1, day: 1, "p:Aquatic": 2, "p:Fresh": 1 } },
      { label: "A romantic date night.", effects: { winter: 1, night: 1, "p:Sweet": 1, "p:Spicy": 1, "proj:Moderate": 1 } },
      { label: "The gym or an active day outdoors.", effects: { summer: 1, day: 1, "p:Citrus": 1, "p:Fresh": 1, "proj:Low": 1 } },
      { label: "A cozy night in or a mountain getaway.", effects: { winter: 1, night: 1, "p:Woody": 1, "p:Gourmand": 1 } },
    ]},
    { phase: "Olfactory Archetypes", q: "If your style were a flavour profile, it would be:", options: [
      { label: "Tart, zesty, sharp, and energising.", effects: { "p:Citrus": 1, "p:Fresh": 2 } },
      { label: "Sweet, velvety, edible, and rich.", effects: { "p:Gourmand": 2, "p:Sweet": 1 } },
      { label: "Dry, earthy, smoky, and sophisticated.", effects: { "p:Woody": 2, "p:Spicy": 1 } },
    ]},
    { phase: "Olfactory Archetypes", q: "How do you feel about floral notes (rose, neroli, iris)?", options: [
      { label: "Keep it clean and soapy, like fresh laundry.", effects: { "p:Floral": 1, "p:Fresh": 1 } },
      { label: "I like dark, rich florals — syrupy rose with oud or amber.", effects: { "p:Floral": 2, "p:Woody": 1, "p:Sweet": 1 } },
      { label: "I prefer to avoid distinct floral notes entirely.", effects: { "p:Woody": 1 } },
    ]},
    // ── Phase 5 · Fashion & Persona ──
    { phase: "Fashion & Persona", q: "What is your daily uniform or go-to style?", options: [
      { label: "Oversized streetwear, clean sneakers, graphic elements.", effects: { "p:Sweet": 1, "proj:High": 1 } },
      { label: "Sharp tailoring, structured blazers, loafers, minimal jewelry.", effects: { "p:Woody": 1, "p:Fresh": 1 } },
      { label: "Vintage jackets, distressed leather, dark edgy silhouettes.", effects: { "p:Leather": 1, "p:Woody": 1, winter: 1 } },
    ]},
    { phase: "Fashion & Persona", q: "What reaction do you want from your fragrance?", options: [
      { label: "“Wow, you smell incredibly clean and fresh.”", effects: { summer: 1, day: 1, "p:Fresh": 1 } },
      { label: "“You smell mysterious, rich, and seductive.”", effects: { winter: 1, night: 1, "p:Spicy": 1 } },
      { label: "“That's the most unique thing I've ever smelled.”", effects: { niche: 2 } },
    ]},
    { phase: "Fashion & Persona", q: "Select the texture that appeals to you most:", options: [
      { label: "Crisp, breathable linen or raw cotton.", effects: { "p:Fresh": 1, "p:Aquatic": 1 } },
      { label: "Heavy warm suede or smooth distressed leather.", effects: { "p:Leather": 2, "p:Woody": 1 } },
      { label: "Soft plush velvet or thick silk.", effects: { "p:Sweet": 1, "p:Gourmand": 1 } },
    ]},
    { phase: "Fashion & Persona", q: "How do you want to feel when you spray this on?", options: [
      { label: "Energised, refreshed, and hyper-focused.", effects: { "p:Citrus": 1, "p:Fresh": 1 } },
      { label: "Confident, commanding, and powerful.", effects: { "p:Woody": 1, "p:Leather": 1, "proj:High": 1 } },
      { label: "Sensual, mysterious, and alluring.", effects: { "p:Sweet": 1, "p:Spicy": 1 } },
    ]},
    { phase: "Fashion & Persona", q: "Which design element catches your eye first?", options: [
      { label: "Bold industrial structures and sharp architectural lines.", effects: { niche: 1, "p:Woody": 1 } },
      { label: "Fluid organic shapes and bright, popping colours.", effects: { designer: 1, "p:Fresh": 1 } },
    ]},
    { phase: "Fashion & Persona", q: "One word to define your personal brand:", options: [
      { label: "Effortless", effects: { "p:Fresh": 1, designer: 1 } },
      { label: "Commanding", effects: { "p:Woody": 1, "p:Leather": 1 } },
      { label: "Unconventional", effects: { niche: 2 } },
      { label: "Luxurious", effects: { expensive: 2 } },
    ]},
  ];

  const quizEl = document.getElementById("quiz");
  const stageEl = document.getElementById("quiz-stage");
  const phaseEl = document.getElementById("quiz-phase");
  const counterEl = document.getElementById("quiz-counter");
  const progressEl = document.getElementById("quiz-progress");
  const KEYS = ["A", "B", "C", "D", "E"];
  const answers: number[] = [];
  let qi = 0;

  type ScoreState = {
    summer: number; winter: number; day: number; night: number;
    affordable: number; expensive: number; designer: number; niche: number;
    gender: { men: number; women: number; unisex: number };
    profiles: Record<string, number>;
    projection: { Low: number; Moderate: number; High: number };
  };
  function blankState(): ScoreState {
    return {
      summer: 0, winter: 0, day: 0, night: 0,
      affordable: 0, expensive: 0, designer: 0, niche: 0,
      gender: { men: 0, women: 0, unisex: 0 },
      profiles: {}, projection: { Low: 0, Moderate: 0, High: 0 },
    };
  }
  function buildState(): ScoreState {
    const s = blankState();
    answers.forEach((ans, idx) => {
      const eff = QUESTIONS[idx]?.options[ans]?.effects;
      if (!eff) return;
      for (const [k, v] of Object.entries(eff)) {
        if (k.startsWith("p:")) s.profiles[k.slice(2)] = (s.profiles[k.slice(2)] || 0) + v;
        else if (k.startsWith("proj:")) s.projection[k.slice(5) as "Low" | "Moderate" | "High"] += v;
        else if (k.startsWith("g:")) s.gender[k.slice(2) as "men" | "women" | "unisex"] += v;
        else (s as any)[k] += v;
      }
    });
    return s;
  }

  // Derive a projection tier for a fragrance from its season / time / families.
  function fragProjection(f: QFrag): "Low" | "Moderate" | "High" {
    let p = f.season === "winter" ? 2 : -1;
    if (f.times.includes("night")) p += 1;
    const fam = f.families;
    if (fam.includes("Gourmand")) p += 2;
    if (fam.includes("Sweet")) p += 1;
    if (fam.includes("Spicy")) p += 1;
    if (fam.includes("Leather")) p += 2;
    if (fam.includes("Woody")) p += 1;
    if (fam.includes("Citrus")) p -= 2;
    if (fam.includes("Aquatic")) p -= 2;
    if (fam.includes("Fresh")) p -= 1;
    if (p >= 4) return "High";
    if (p <= 0) return "Low";
    return "Moderate";
  }

  function matchScore(f: QFrag, s: ScoreState): number {
    let score = 0;
    score += f.season === "summer" ? s.summer : s.winter;
    for (const t of f.times) score += (t === "day" ? s.day : s.night) * 0.5;
    score += f.houseType === "designer" ? s.designer : s.niche;
    score += (f.priceTier === "budget" ? s.affordable : s.expensive) * 0.5;
    for (const fam of f.families) score += s.profiles[fam] || 0;
    score += s.projection[fragProjection(f)] || 0;
    return score;
  }

  function recommend() {
    const s = buildState();
    let pool = quizFrags.slice();
    // Base filter: highest-scored gender (men excludes women's & vice-versa;
    // unisex keeps everything).
    const topGender = (["men", "women", "unisex"] as const).reduce(
      (a, b) => (s.gender[b] > s.gender[a] ? b : a), "men" as "men" | "women" | "unisex");
    if (topGender === "men") pool = pool.filter((f) => f.gender !== "women");
    else if (topGender === "women") pool = pool.filter((f) => f.gender !== "men");
    if (pool.length === 0) pool = quizFrags.slice();
    // Hard boundary: budget vs premium.
    if (s.affordable > s.expensive) pool = pool.filter((f) => f.priceTier === "budget");
    else if (s.expensive > s.affordable) pool = pool.filter((f) => f.priceTier === "premium");
    if (pool.length === 0) pool = quizFrags.slice();

    const scored = pool
      .map((f) => ({ f, score: matchScore(f, s) }))
      .sort((a, b) => b.score - a.score);
    const used = new Set<string>();
    const pick = (test: (f: QFrag) => boolean): QFrag | undefined => {
      for (const it of scored) if (!used.has(it.f.id) && test(it.f)) { used.add(it.f.id); return it.f; }
      for (const it of scored) if (test(it.f)) return it.f;
      return scored[0]?.f;
    };
    return [
      { label: "Top for Summer", f: pick((f) => f.season === "summer") },
      { label: "Top for Winter", f: pick((f) => f.season === "winter") },
      { label: "Top for Day", f: pick((f) => f.times.includes("day")) },
      { label: "Top for Night", f: pick((f) => f.times.includes("night")) },
    ];
  }

  function setProgress(label: string, counter: string, pct: number) {
    if (phaseEl) phaseEl.textContent = label;
    if (counterEl) counterEl.textContent = counter;
    if (progressEl) (progressEl as HTMLElement).style.width = `${pct}%`;
  }

  function renderQuestion() {
    if (!stageEl) return;
    const q = QUESTIONS[qi];
    setProgress(q.phase, `${qi + 1} / ${QUESTIONS.length}`, ((qi + 1) / QUESTIONS.length) * 100);
    stageEl.innerHTML = `
      <div class="quiz-q">
        <p class="eyebrow">Question ${qi + 1}</p>
        <h2 class="font-display mt-3 text-2xl font-light leading-snug tracking-tight md:text-4xl">${q.q}</h2>
        <div class="mt-8 flex flex-col gap-3">
          ${q.options.map((o, i) => `
            <button class="quiz-opt" data-opt="${i}">
              <span class="opt-key">${KEYS[i]}</span>
              <span class="pt-0.5 text-sm md:text-base">${o.label}</span>
            </button>`).join("")}
        </div>
        ${qi > 0 ? `<button id="quiz-back" class="mt-7 text-xs uppercase tracking-[0.18em]" style="color:var(--text-faint)">← Back</button>` : ""}
      </div>`;
    stageEl.querySelectorAll<HTMLButtonElement>(".quiz-opt").forEach((btn) => {
      btn.addEventListener("click", () => choose(parseInt(btn.dataset.opt || "0", 10)));
    });
    document.getElementById("quiz-back")?.addEventListener("click", () => { if (qi > 0) { qi--; renderQuestion(); } });
    document.querySelector(".quiz-scroll")?.scrollTo({ top: 0 });
  }

  function choose(i: number) {
    answers[qi] = i;
    if (qi >= QUESTIONS.length - 1) renderResults();
    else { qi++; renderQuestion(); }
  }

  function renderResults() {
    if (!stageEl) return;
    setProgress("Your Edit", "Done", 100);
    const recs = recommend();
    const cards = recs.map((r) => {
      const f = r.f;
      if (!f) return "";
      return `
        <button class="quiz-result-card group flex flex-col items-center p-4 text-center sm:items-start sm:text-left" data-result-id="${f.id}">
          <span class="text-[0.6rem] uppercase tracking-[0.2em]" style="color:var(--accent)">${r.label}</span>
          <div class="relative my-3 flex h-36 w-full items-center justify-center">
            <div class="absolute inset-0 m-auto h-24 w-24 rounded-full" style="background:radial-gradient(circle, ${f.accent[0]}, transparent 70%);filter:blur(28px);opacity:.5"></div>
            <img src="${f.image}" alt="${f.brand} ${f.name}" class="relative h-full w-auto object-contain" />
          </div>
          <span class="text-base font-bold leading-tight">${f.brand}</span>
          <span class="text-sm font-light" style="color:var(--text-muted)">${f.name}</span>
          <span class="mt-3 text-[0.6rem] uppercase tracking-[0.18em]" style="color:var(--text-faint)">View details +</span>
        </button>`;
    }).join("");
    stageEl.innerHTML = `
      <div class="quiz-q">
        <p class="eyebrow">Your Signature Edit</p>
        <h2 class="font-display mt-3 text-3xl font-light tracking-tight md:text-5xl">Four scents, chosen for you.</h2>
        <p class="mt-4 max-w-xl text-sm" style="color:var(--text-muted)">Based on your ${QUESTIONS.length} answers — the best match for each season and time of day, within your budget.</p>
        <div class="mt-8 grid grid-cols-2 gap-4 lg:grid-cols-4">${cards}</div>
        <div class="mt-9 flex flex-col gap-3 sm:flex-row">
          <button id="quiz-restart" class="btn-ghost rounded-full px-6 py-3 text-xs uppercase tracking-[0.18em]">Retake quiz</button>
          <button id="quiz-explore" class="btn-accent rounded-full px-6 py-3 text-xs uppercase tracking-[0.18em]">Explore full catalog</button>
        </div>
      </div>`;
    stageEl.querySelectorAll<HTMLButtonElement>("[data-result-id]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const id = btn.dataset.resultId || "";
        // Keep the quiz results open underneath; the drawer layers on top, so
        // closing the drawer returns to the four assorted picks.
        const gridBtn = document.querySelector<HTMLElement>(`#grid [data-open-drawer][data-id="${id}"]`);
        if (gridBtn) openDrawer(gridBtn);
      });
    });
    document.getElementById("quiz-restart")?.addEventListener("click", startQuiz);
    document.getElementById("quiz-explore")?.addEventListener("click", () => {
      closeQuiz();
      document.getElementById("catalogue")?.scrollIntoView({ behavior: "smooth" });
    });
    document.querySelector(".quiz-scroll")?.scrollTo({ top: 0 });
  }

  function startQuiz() { qi = 0; answers.length = 0; quizEl?.classList.add("open"); document.body.style.overflow = "hidden"; renderQuestion(); }
  function closeQuiz() { quizEl?.classList.remove("open"); document.body.style.overflow = ""; }

  document.getElementById("open-quiz")?.addEventListener("click", startQuiz);
  document.getElementById("quiz-close")?.addEventListener("click", closeQuiz);

  // ─── Hero CTA: cursor-mask paint blob that "drags" toward the pointer ────
  const quizBtn = document.getElementById("open-quiz") as HTMLElement | null;
  if (quizBtn && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    let tx = 0, ty = 0, cx = 0, cy = 0, raf = 0, inside = false;
    const setVars = () => {
      quizBtn.style.setProperty("--mx", `${cx}px`);
      quizBtn.style.setProperty("--my", `${cy}px`);
    };
    const tick = () => {
      cx += (tx - cx) * 0.16; // lower factor = more "drag"/lag
      cy += (ty - cy) * 0.16;
      setVars();
      if (inside || Math.abs(tx - cx) > 0.4 || Math.abs(ty - cy) > 0.4) {
        raf = requestAnimationFrame(tick);
      } else raf = 0;
    };
    quizBtn.addEventListener("pointerenter", (e) => {
      inside = true;
      const r = quizBtn.getBoundingClientRect();
      tx = e.clientX - r.left; ty = e.clientY - r.top;
      cx = tx; cy = ty; // snap on entry so the blob doesn't fly in from a corner
      setVars();
      if (!raf) raf = requestAnimationFrame(tick);
    });
    quizBtn.addEventListener("pointermove", (e) => {
      const r = quizBtn.getBoundingClientRect();
      tx = e.clientX - r.left; ty = e.clientY - r.top;
      if (!raf) raf = requestAnimationFrame(tick);
    });
    quizBtn.addEventListener("pointerleave", () => { inside = false; });
  }

  document.addEventListener("keydown", (e) => {
    if (e.key !== "Escape") return;
    // The drawer's own Escape handler closes it first; don't also close the quiz.
    if (drawer?.classList.contains("open")) return;
    if (quizEl?.classList.contains("open")) closeQuiz();
    if (dict?.classList.contains("open")) closeDict();
  });
</script>
