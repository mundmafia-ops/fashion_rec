<script>
  import { firebaseReady, signInWithGoogle, signOut, watchAuth, type User } from "@/lib/firebase";

  // ─── Amazon marketplace localisation ─────────────────────────────────────
  // Links are baked at build time as US search URLs (amazon.com, tag
  // fragrandise-20). We ask /api/geo for the visitor's country (Vercel's
  // geo-IP header) and, for India, swap the domain + Associates tag to the
  // amazon.in store (fragrandise-21). localizeAmazon() always rebuilds from the
  // `k` search term, so it's idempotent and safe to run repeatedly.
  const AMZ = { tld: "com", tag: "fragrandise-20" };
  function localizeAmazon(url: string): string {
    if (!url || url === "#") return url || "#";
    try {
      const u = new URL(url, location.href);
      if (!/(^|\.)amazon\./.test(u.hostname)) return url;
      const k = u.searchParams.get("k");
      if (!k) return url; // not a search link — leave untouched
      return `https://www.amazon.${AMZ.tld}/s?k=${encodeURIComponent(k)}&tag=${AMZ.tag}`;
    } catch { return url; }
  }
  function rewriteAmazonLinks() {
    document.querySelectorAll<HTMLAnchorElement>('a[href*="amazon."]').forEach((a) => {
      a.href = localizeAmazon(a.href);
    });
  }
  fetch("/api/geo")
    .then((r) => (r.ok ? r.json() : null))
    .then((d) => {
      if (d && d.country === "IN") {
        AMZ.tld = "in";
        AMZ.tag = "fragrandise-21";
        rewriteAmazonLinks();
      }
    })
    .catch(() => {});

  // ─── Theme toggle ───────────────────────────────────────────────────────
  const root = document.documentElement;
  const toggle = document.getElementById("theme-toggle");
  const moon = document.getElementById("icon-moon");
  const sun = document.getElementById("icon-sun");
  function syncIcons() {
    const light = root.getAttribute("data-theme") === "light";
    if (moon) moon.style.display = light ? "none" : "block";
    if (sun) sun.style.display = light ? "block" : "none";
  }
  syncIcons();
  toggle?.addEventListener("click", () => {
    const next = root.getAttribute("data-theme") === "light" ? "dark" : "light";
    root.setAttribute("data-theme", next);
    try { localStorage.setItem("fr-theme", next); } catch (e) {}
    syncIcons();
  });

  // ─── Mobile/browser Back-button handling for overlays ────────────────────
  // Each overlay (product drawer, quiz, wishlist, dictionary) pushes a history
  // entry when it opens. The phone Back button (popstate) then closes the
  // top-most overlay instead of leaving the site — so Back from a product card
  // returns to whatever the visitor was browsing. Closing via the page's own
  // buttons/Esc rewinds that same history entry, keeping the stack in sync.
  const frStack: { name: string; domClose: () => void }[] = [];
  function frOpen(name: string, domClose: () => void) {
    if (frStack.some((o) => o.name === name)) return; // already tracked
    frStack.push({ name, domClose });
    try { history.pushState({ frDepth: frStack.length }, ""); } catch (e) {}
  }
  function frRequestClose(name: string): boolean {
    const i = frStack.map((o) => o.name).lastIndexOf(name);
    if (i === -1) return false;           // not tracked → caller closes directly
    history.go(-(frStack.length - i));    // rewind → fires popstate → domClose
    return true;
  }
  window.addEventListener("popstate", () => {
    const depth = (history.state && typeof history.state.frDepth === "number")
      ? history.state.frDepth : 0;
    while (frStack.length > depth) frStack.pop()?.domClose();
  });

  // ─── Header on scroll ───────────────────────────────────────────────────
  const header = document.getElementById("site-header");
  const onScroll = () => {
    if (!header) return;
    if (window.scrollY > 24) {
      header.style.background = "color-mix(in srgb, var(--bg) 82%, transparent)";
      header.style.backdropFilter = "blur(18px)";
      header.style.borderBottom = "1px solid var(--border)";
    } else {
      header.style.background = "transparent";
      header.style.backdropFilter = "none";
      header.style.borderBottom = "1px solid transparent";
    }
  };
  onScroll();
  window.addEventListener("scroll", onScroll, { passive: true });

  // ─── Parallax ───────────────────────────────────────────────────────────
  const parallaxEls = Array.from(document.querySelectorAll<HTMLElement>("[data-parallax]"));
  let ticking = false;
  window.addEventListener("scroll", () => {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(() => {
      const y = window.scrollY;
      for (const el of parallaxEls) {
        const speed = parseFloat(el.dataset.parallax || "0");
        el.style.transform = `translateY(${y * speed}px)`;
      }
      ticking = false;
    });
  }, { passive: true });

  // ─── Reveal on scroll ───────────────────────────────────────────────────
  const io = new IntersectionObserver((entries) => {
    for (const e of entries) {
      if (e.isIntersecting) { e.target.classList.add("in"); io.unobserve(e.target); }
    }
  }, { threshold: 0.12, rootMargin: "0px 0px -8% 0px" });
  document.querySelectorAll("[data-reveal]").forEach((el) => io.observe(el));

  // ─── Carousel (draggable slider + tap to view in catalogue) ─────────────
  // Assigned inside the carousel block; called by the shared setGender().
  let repopulateCarousel: ((g: string) => void) | null = null;
  const carouselEl = document.getElementById("carousel");
  if (carouselEl) {
    const crItems = Array.from(carouselEl.querySelectorAll<HTMLElement>(".cr-item"));
    const n = crItems.length;
    let pos = 0; // fractional position; round() = active bottle
    let crTimer: number | undefined;
    let crPause: number | undefined;

    const dotsWrap = document.getElementById("cr-dots");
    crItems.forEach((_, i) => {
      const d = document.createElement("button");
      d.className = "cr-dot";
      d.setAttribute("aria-label", `Go to bottle ${i + 1}`);
      d.addEventListener("click", () => { pos = i; layout(); restart(4000); });
      dotsWrap?.appendChild(d);
    });
    const dots = Array.from(dotsWrap?.children || []) as HTMLElement[];

    const spacingOf = () => {
      const cw = carouselEl.clientWidth || 480;
      return Math.max(86, Math.min(150, cw * 0.26));
    };
    const activeIndex = () => ((Math.round(pos) % n) + n) % n;
    // Per-frame blur is the main mobile-repaint/flicker source — skip it on
    // small/touch screens, keep the soft depth blur on desktop.
    const noBlur = window.matchMedia("(max-width: 640px), (hover: none)").matches;

    function layout() {
      const spacing = spacingOf();
      const ai = activeIndex();
      crItems.forEach((el, i) => {
        let off = i - pos;
        while (off > n / 2) off -= n;
        while (off < -n / 2) off += n;
        const a = Math.abs(off);
        el.style.transform = `translate(-50%,-50%) translateX(${off * spacing}px) scale(${Math.max(0.55, 1.08 - a * 0.16)})`;
        el.style.opacity = String(a > 2.6 ? 0 : 1 - a * 0.26);
        el.style.zIndex = String(100 - Math.round(a));
        el.style.filter = noBlur || a < 0.5 ? "none" : `blur(${a * 0.7}px)`;
        el.classList.toggle("is-active", i === ai);
        dots[i]?.classList.toggle("active", i === ai);
      });
    }

    // restart(delay): wait `delay` ms (e.g. after a manual nudge) before
    // resuming the auto-rotation, so user clicks don't fight the cycle.
    function restart(delay = 0) {
      if (crTimer) { clearInterval(crTimer); crTimer = undefined; }
      if (crPause) { clearTimeout(crPause); crPause = undefined; }
      const begin = () => { crTimer = window.setInterval(() => { pos = Math.round(pos) + 1; layout(); }, 3600); };
      if (delay > 0) crPause = window.setTimeout(begin, delay);
      else begin();
    }
    function stop() {
      if (crTimer) { clearInterval(crTimer); crTimer = undefined; }
      if (crPause) { clearTimeout(crPause); crPause = undefined; }
    }

    document.getElementById("cr-prev")?.addEventListener("click", () => { pos = Math.round(pos) - 1; layout(); restart(4000); });
    document.getElementById("cr-next")?.addEventListener("click", () => { pos = Math.round(pos) + 1; layout(); restart(4000); });

    // open the matching fragrance in the catalogue
    function openFromCarousel(id: string | null) {
      if (!id) return;
      const btn = document.querySelector<HTMLElement>(`#grid [data-open-drawer][data-id="${id}"]`);
      if (!btn) return;
      const wrap = btn.closest(".card-wrap");
      wrap?.classList.remove("hidden-card");
      wrap?.scrollIntoView({ behavior: "smooth", block: "center" });
      openDrawer(btn);
    }

    // drag to slide (window-level so native clicks on bottles still fire)
    let dragging = false, startX = 0, startY = 0, startPos = 0, moved = 0, spc = 120;
    carouselEl.addEventListener("pointerdown", (e) => {
      dragging = true; startX = e.clientX; startY = e.clientY; startPos = pos; moved = 0; spc = spacingOf();
      stop();
      carouselEl.classList.add("dragging");
    });
    window.addEventListener("pointermove", (e) => {
      if (!dragging) return;
      const dx = e.clientX - startX;
      moved = Math.max(moved, Math.abs(dx), Math.abs(e.clientY - startY));
      pos = startPos - dx / spc;
      layout();
    });
    function endDrag(e?: PointerEvent) {
      if (!dragging) return;
      dragging = false;
      carouselEl?.classList.remove("dragging");
      // a tap (no real drag) → open that bottle's details
      if (moved <= 6 && e) {
        const el = (document.elementFromPoint(e.clientX, e.clientY) as HTMLElement | null)?.closest(".cr-item");
        if (el) openFromCarousel(el.getAttribute("data-id"));
      }
      pos = Math.round(pos);
      layout();
      restart(4000);
    }
    window.addEventListener("pointerup", endDrag);
    window.addEventListener("pointercancel", () => endDrag());

    // also handle plain clicks (mouse) as a fallback
    crItems.forEach((el) => {
      el.addEventListener("click", () => {
        if (moved > 6) return;
        openFromCarousel(el.getAttribute("data-id"));
      });
    });

    carouselEl.addEventListener("pointerenter", () => { if (!dragging) stop(); });
    carouselEl.addEventListener("pointerleave", () => { if (!dragging) restart(); });
    window.addEventListener("resize", layout);
    layout();
    restart();

    // ── gender toggle: swap the 12 bottles + filter the catalogue grid ──
    const carouselData = JSON.parse(document.getElementById("carousel-data")?.textContent || "{}");
    function populateCarousel(gender: string) {
      const items = carouselData[gender] || [];
      crItems.forEach((el, i) => {
        const d = items[i];
        if (!d) { el.style.display = "none"; return; }
        el.style.display = "";
        el.setAttribute("data-id", d.id);
        el.setAttribute("data-group", d.group);
        el.querySelector(".cr-aura")?.setAttribute("data-temp", d.temp);
        const img = el.querySelector("img");
        if (img) { (img as HTMLImageElement).src = d.image; img.setAttribute("alt", `${d.brand} ${d.name} bottle`); }
        const setTxt = (sel: string, t: string) => { const n = el.querySelector(sel); if (n) n.textContent = t; };
        setTxt(".cr-group", d.group); setTxt(".cr-brand", d.brand); setTxt(".cr-name", d.name);
      });
      pos = 0; layout(); restart(4000);
    }
    repopulateCarousel = populateCarousel;
  }

  // ─── Filtering ──────────────────────────────────────────────────────────
  const cards = Array.from(document.querySelectorAll<HTMLElement>(".card-wrap"));
  const countEl = document.getElementById("result-count");
  const emptyEl = document.getElementById("empty-state");
  const total = cards.length;

  const active = {
    gender: new Set<string>(["men"]), // multi-select grid filter; men preselected
    mood: new Set<string>(),
    price: new Set<string>(),
    house: new Set<string>(),
    sillage: new Set<string>(),
    projection: new Set<string>(),
    family: new Set<string>(),
  };
  let searchQuery = "";

  function applyFilters() {
    let shown = 0;
    for (const card of cards) {
      const season = card.dataset.season || "";
      const times = (card.dataset.times || "").split(" ");
      const price = card.dataset.price || "";
      const house = card.dataset.house || "";
      const gender = card.dataset.gender || "men";
      const sillage = card.dataset.sillage || "";
      const projection = card.dataset.projection || "";
      const families = (card.dataset.families || "").split(" ");

      const okGender = active.gender.size === 0 || active.gender.has(gender);
      const okMood = active.mood.size === 0 ||
        [...active.mood].some((m) => season === m || times.includes(m));
      const okPrice = active.price.size === 0 || active.price.has(price);
      const okHouse = active.house.size === 0 || active.house.has(house);
      const okSillage = active.sillage.size === 0 || active.sillage.has(sillage);
      const okProjection = active.projection.size === 0 || active.projection.has(projection);
      const okFamily = active.family.size === 0 ||
        families.some((fam) => active.family.has(fam));
      const okSearch = searchQuery === "" || (card.dataset.search || "").includes(searchQuery);

      const visible = okSearch && okGender && okMood && okPrice && okHouse && okSillage && okProjection && okFamily;
      card.classList.toggle("hidden-card", !visible);
      if (visible) shown++;
    }
    if (countEl) countEl.textContent = `Showing ${shown} of ${total}`;
    if (emptyEl) emptyEl.classList.toggle("hidden", shown !== 0);
  }
  applyFilters(); // enforce the default (men) gender view on load

  // ─── Wishlist ────────────────────────────────────────────────────────────
  // A personal shortlist of fragrances. This is an editorial blog, so nothing
  // is purchasable — the wishlist just remembers what you're curious about,
  // persisted to localStorage on the visitor's own device.
  const WKEY = "fr-wishlist";
  function readWishlist(): Set<string> {
    try { return new Set<string>(JSON.parse(localStorage.getItem(WKEY) || "[]")); }
    catch (e) { return new Set<string>(); }
  }
  let wishlist = readWishlist();
  function saveWishlist() {
    try { localStorage.setItem(WKEY, JSON.stringify([...wishlist])); } catch (e) {}
  }

  // id → { brand, name, image, accent } lookup, reused from the quiz payload.
  const wishLookup: Record<string, any> = {};
  try {
    const arr = JSON.parse(document.getElementById("quiz-frag-data")?.textContent || "[]");
    for (const f of arr) wishLookup[f.id] = f;
  } catch (e) {}

  const wishDrawer = document.getElementById("wishlist-drawer");
  const wishListEl = document.getElementById("wishlist-list");
  const wishEmptyEl = document.getElementById("wishlist-empty");
  const wishCountEl = document.getElementById("wishlist-count");
  const wishCountMEl = document.getElementById("wishlist-count-m");
  const wishOpenBtn = document.getElementById("wishlist-open");
  const wishIconHeart = document.getElementById("wishlist-icon-heart");
  const wishIconSignin = document.getElementById("wishlist-icon-signin");

  function syncWishUI() {
    document.querySelectorAll<HTMLElement>("[data-wish]").forEach((btn) => {
      const id = btn.getAttribute("data-id") || "";
      const on = !!id && wishlist.has(id);
      btn.setAttribute("aria-pressed", String(on));
      btn.classList.toggle("is-wished", on);
      if (btn.id === "d-wishlist") {
        const label = btn.querySelector(".wish-cta-label");
        if (label) label.textContent = on ? "Saved to Wishlist" : "Add to Wishlist";
      }
    });
    const n = wishlist.size;
    if (wishCountEl) { wishCountEl.textContent = String(n); (wishCountEl as HTMLElement).hidden = n === 0; }
    if (wishCountMEl) wishCountMEl.textContent = n ? `(${n})` : "";
    if (wishDrawer?.classList.contains("open")) renderWishlist();
  }

  function renderWishlist() {
    if (!wishListEl || !wishEmptyEl) return;
    const ids = [...wishlist];
    if (ids.length === 0) {
      wishListEl.classList.add("hidden"); wishListEl.classList.remove("flex");
      wishEmptyEl.classList.remove("hidden"); wishEmptyEl.classList.add("flex");
      return;
    }
    wishEmptyEl.classList.add("hidden"); wishEmptyEl.classList.remove("flex");
    wishListEl.classList.remove("hidden"); wishListEl.classList.add("flex");
    wishListEl.innerHTML = ids.map((id) => {
      const f = wishLookup[id];
      if (!f) return "";
      const from = f.accent?.[0] || "#888";
      return `
        <div class="wish-row flex items-center gap-4 rounded-2xl border p-3" style="border-color:var(--border);background:var(--surface)">
          <div class="relative grid h-16 w-16 shrink-0 place-items-center rounded-xl" style="background:var(--bg-soft)">
            <div class="absolute inset-0 m-auto h-10 w-10 rounded-full" style="background:radial-gradient(circle, ${from}, transparent 70%);filter:blur(14px);opacity:.6"></div>
            <img src="${f.image}" alt="${f.brand} ${f.name}" class="relative h-14 w-auto object-contain" />
          </div>
          <button type="button" class="min-w-0 flex-1 text-left" data-wish-view="${id}">
            <p class="truncate text-sm font-bold leading-tight">${f.brand}</p>
            <p class="truncate text-xs font-light" style="color:var(--text-muted)">${f.name}</p>
            <span class="mt-1 inline-block text-[0.58rem] uppercase tracking-[0.16em]" style="color:var(--accent)">View details +</span>
          </button>
          <button type="button" aria-label="Remove from wishlist" title="Remove" class="wish-remove grid h-8 w-8 shrink-0 place-items-center rounded-full border" data-wish-remove="${id}" style="border-color:var(--border-strong);color:var(--text-muted)">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"></path></svg>
          </button>
        </div>`;
    }).join("");
    wishListEl.querySelectorAll<HTMLElement>("[data-wish-remove]").forEach((b) =>
      b.addEventListener("click", () => { wishlist.delete(b.dataset.wishRemove || ""); saveWishlist(); syncWishUI(); }));
    wishListEl.querySelectorAll<HTMLElement>("[data-wish-view]").forEach((b) =>
      b.addEventListener("click", () => {
        const gridBtn = document.querySelector<HTMLElement>(`#grid [data-open-drawer][data-id="${b.dataset.wishView}"]`);
        if (gridBtn) openDrawer(gridBtn);
      }));
  }

  function toggleWish(id: string) {
    if (!id) return;
    // Removing a saved scent never needs a login. Adding one does — gate it
    // behind Google sign-in (only when Firebase is configured; otherwise the
    // wishlist stays fully usable as a local-only shortlist).
    if (wishlist.has(id)) {
      wishlist.delete(id);
    } else {
      if (!ensureSignedIn(() => toggleWish(id))) return;
      wishlist.add(id);
    }
    saveWishlist();
    syncWishUI();
  }

  // ─── Google sign-in gate ─────────────────────────────────────────────────
  let currentUser: User | null = null;
  let pendingAction: (() => void) | null = null; // re-run once sign-in lands

  // Returns true if the visitor may proceed (already signed in, or Firebase is
  // not configured). Otherwise it stashes `retry`, opens the sign-in modal, and
  // returns false — the caller should bail and let the retry fire post-login.
  function ensureSignedIn(retry: () => void): boolean {
    if (!firebaseReady || currentUser) return true;
    pendingAction = retry;
    openSignIn();
    return false;
  }

  const signinModal = document.getElementById("signin-modal");
  const signinErr = document.getElementById("signin-error");
  const signinBtn = document.getElementById("signin-google") as HTMLButtonElement | null;
  const signinLabel = document.getElementById("signin-google-label");

  function openSignIn() {
    if (!signinModal) return;
    signinErr?.classList.add("hidden");
    signinModal.classList.remove("hidden");
    document.body.style.overflow = "hidden";
    frOpen("signin", closeSignInDOM);
  }
  function closeSignInDOM() {
    signinModal?.classList.add("hidden");
    const stillLocked = document.getElementById("drawer")?.classList.contains("open") ||
      document.getElementById("quiz")?.classList.contains("open") ||
      wishDrawer?.classList.contains("open");
    document.body.style.overflow = stillLocked ? "hidden" : "";
  }
  function closeSignIn() {
    pendingAction = null;
    if (frRequestClose("signin")) return;
    closeSignInDOM();
  }

  signinBtn?.addEventListener("click", async () => {
    signinErr?.classList.add("hidden");
    signinBtn.disabled = true;
    if (signinLabel) signinLabel.textContent = "Signing in…";
    try {
      await signInWithGoogle();
      // onAuthStateChanged (below) flushes the pending save and closes the modal.
    } catch (err: any) {
      if (signinErr) {
        signinErr.textContent = err?.code === "auth/popup-closed-by-user"
          ? "Sign-in was cancelled."
          : "Couldn't sign in. Please try again.";
        signinErr.classList.remove("hidden");
      }
    } finally {
      signinBtn.disabled = false;
      if (signinLabel) signinLabel.textContent = "Continue with Google";
    }
  });
  document.querySelectorAll("[data-close-signin]").forEach((el) =>
    el.addEventListener("click", closeSignIn));

  // Account strip inside the wishlist drawer.
  const acctStrip = document.getElementById("wish-account");
  const acctAvatar = document.getElementById("wish-account-avatar") as HTMLImageElement | null;
  const acctInitial = document.getElementById("wish-account-initial");
  const acctName = document.getElementById("wish-account-name");
  const acctEmail = document.getElementById("wish-account-email");
  document.getElementById("wish-signout")?.addEventListener("click", () => { signOut(); });

  // Show the photo when it loads, fall back to the user's initial otherwise.
  // Google avatars (lh3.googleusercontent.com) 403 if a referrer is sent — the
  // img carries referrerpolicy="no-referrer", but we still guard against a miss.
  function showInitialFallback() {
    acctAvatar?.classList.add("hidden");
    acctInitial?.classList.remove("hidden");
  }
  acctAvatar?.addEventListener("error", showInitialFallback);
  acctAvatar?.addEventListener("load", () => {
    acctAvatar.classList.remove("hidden");
    acctInitial?.classList.add("hidden");
  });

  // Swap the header trigger between a "sign in" arrow (signed-out) and the
  // heart (signed in). Only meaningful when Firebase auth is configured —
  // otherwise the wishlist is a local-only shortlist and stays a heart.
  function syncWishlistTrigger() {
    const signedOut = firebaseReady && !currentUser;
    wishIconHeart?.style.setProperty("display", signedOut ? "none" : "");
    wishIconSignin?.style.setProperty("display", signedOut ? "" : "none");
    if (wishOpenBtn) {
      const label = signedOut ? "Sign in" : "Wishlist";
      wishOpenBtn.setAttribute("aria-label", label);
      wishOpenBtn.setAttribute("title", label);
    }
  }

  function syncAccountUI() {
    syncWishlistTrigger();
    if (!acctStrip) return;
    if (currentUser) {
      acctStrip.classList.remove("hidden");
      acctStrip.classList.add("flex");
      const name = currentUser.displayName || currentUser.email || "Signed in";
      if (acctInitial) acctInitial.textContent = name.trim().charAt(0).toUpperCase() || "?";
      if (acctAvatar) {
        const photo = currentUser.photoURL || "";
        if (photo) { acctAvatar.src = photo; } else { showInitialFallback(); }
      }
      if (acctName) acctName.textContent = currentUser.displayName || "Signed in";
      if (acctEmail) acctEmail.textContent = currentUser.email || "";
    } else {
      acctStrip.classList.add("hidden");
      acctStrip.classList.remove("flex");
    }
  }

  // Reflect the signed-out state immediately; watchAuth refines it once auth resolves.
  syncWishlistTrigger();

  if (firebaseReady) {
    watchAuth((user) => {
      currentUser = user;
      syncAccountUI();
      if (user) {
        // Finish the action the visitor started before the login prompt (if any),
        // then dismiss the modal — covers header-initiated sign-ins too.
        if (pendingAction) {
          const action = pendingAction;
          pendingAction = null;
          action();
        }
        closeSignInDOM();
      }
    });
  }

  // Bind every heart toggle once (idempotent — safe to re-run on injected DOM).
  function bindWishButtons(scope: ParentNode = document) {
    scope.querySelectorAll<HTMLElement>("[data-wish]").forEach((btn) => {
      if (btn.dataset.wishBound) return;
      btn.dataset.wishBound = "1";
      btn.addEventListener("click", (e) => {
        e.preventDefault();
        e.stopPropagation();
        toggleWish(btn.getAttribute("data-id") || "");
      });
      // span-based hearts (inside the card <button>) need explicit key handling
      btn.addEventListener("keydown", (e) => {
        if (e.key !== "Enter" && e.key !== " ") return;
        e.preventDefault();
        e.stopPropagation();
        toggleWish(btn.getAttribute("data-id") || "");
      });
    });
  }

  function openWishlist() { wishDrawer?.classList.add("open"); document.body.style.overflow = "hidden"; renderWishlist(); frOpen("wishlist", closeWishlistDOM); }
  function closeWishlistDOM() {
    wishDrawer?.classList.remove("open");
    const stillLocked = document.getElementById("drawer")?.classList.contains("open") ||
      document.getElementById("quiz")?.classList.contains("open");
    document.body.style.overflow = stillLocked ? "hidden" : "";
  }
  function closeWishlist() {
    if (frRequestClose("wishlist")) return;
    closeWishlistDOM();
  }
  // When signed out (and auth is configured) the header trigger is a sign-in
  // arrow, so it opens the login modal instead of the wishlist drawer.
  function openWishlistOrSignIn() {
    if (firebaseReady && !currentUser) { openSignIn(); return; }
    openWishlist();
  }
  document.getElementById("wishlist-open")?.addEventListener("click", openWishlistOrSignIn);
  document.getElementById("wishlist-open-m")?.addEventListener("click", openWishlist);
  document.querySelectorAll("[data-close-wishlist]").forEach((el) => el.addEventListener("click", closeWishlist));

  bindWishButtons();
  syncWishUI();

  // Carousel gender toggle: single-select, controls the carousel bottles only.
  document.querySelectorAll<HTMLButtonElement>(".gender-link[data-gender]").forEach((btn) =>
    btn.addEventListener("click", () => {
      const g = btn.dataset.gender || "men";
      document.querySelectorAll<HTMLButtonElement>(".gender-link[data-gender]").forEach((b) =>
        b.setAttribute("aria-pressed", String(b.dataset.gender === g)));
      repopulateCarousel?.(g);
    }));

  // sidebar chips — multi-select (gender / price / house / family alike)
  document.querySelectorAll<HTMLButtonElement>(".chip[data-group]").forEach((chip) => {
    chip.addEventListener("click", () => {
      const group = chip.dataset.group as "gender" | "price" | "house" | "sillage" | "projection" | "family";
      const value = chip.dataset.value || "";
      const set = active[group];
      if (set.has(value)) { set.delete(value); chip.setAttribute("aria-pressed", "false"); }
      else { set.add(value); chip.setAttribute("aria-pressed", "true"); }
      applyFilters();
    });
  });

  // seasonal category cards
  document.querySelectorAll<HTMLButtonElement>(".catcard[data-mood]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const value = btn.dataset.mood || "";
      if (active.mood.has(value)) { active.mood.delete(value); btn.setAttribute("aria-pressed", "false"); }
      else { active.mood.add(value); btn.setAttribute("aria-pressed", "true"); }
      applyFilters();
    });
  });

  // ─── Search box ─────────────────────────────────────────────────────────
  const searchInput = document.getElementById("grid-search") as HTMLInputElement | null;
  const searchClear = document.getElementById("grid-search-clear");
  searchInput?.addEventListener("input", () => {
    searchQuery = searchInput.value.trim().toLowerCase();
    searchClear?.classList.toggle("hidden", searchQuery === "");
    applyFilters();
  });
  searchClear?.addEventListener("click", () => {
    if (searchInput) searchInput.value = "";
    searchQuery = "";
    searchClear.classList.add("hidden");
    applyFilters();
    searchInput?.focus();
  });

  document.getElementById("reset-filters")?.addEventListener("click", () => {
    active.gender.clear(); active.mood.clear(); active.price.clear(); active.house.clear();
    active.sillage.clear(); active.projection.clear(); active.family.clear();
    searchQuery = "";
    if (searchInput) searchInput.value = "";
    searchClear?.classList.add("hidden");
    document.querySelectorAll("[aria-pressed]").forEach((c) => {
      const el = c as HTMLElement;
      if (el.id === "theme-toggle" || el.classList.contains("gender-link")) return;
      el.setAttribute("aria-pressed", "false");
    });
    document.querySelectorAll(".nav-link[data-nav-mood]").forEach((n) => n.classList.remove("nav-active"));
    applyFilters();
  });

  // ─── Drawer ─────────────────────────────────────────────────────────────
  const drawer = document.getElementById("drawer");
  const dBottle = document.getElementById("d-bottle");
  const dGlow = document.getElementById("d-glow");

  const tierIcon: Record<string, string> = {
    Top: `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v6"/><path d="M12 9c-3 0-5 2-5 5a5 5 0 0 0 10 0c0-3-2-5-5-5Z"/><path d="M9 4c1.5.5 3 .5 3 2"/></svg>`,
    Heart: `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="2.5"/><path d="M12 9.5c0-2.5 1-4.5 0-6.5-1 2 0 4 0 6.5Z"/><path d="M12 14.5c0 2.5-1 4.5 0 6.5 1-2 0-4 0-6.5Z"/><path d="M9.5 12c-2.5 0-4.5-1-6.5 0 2 1 4 0 6.5 0Z"/><path d="M14.5 12c2.5 0 4.5 1 6.5 0-2-1-4 0-6.5 0Z"/></svg>`,
    Base: `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 4 3 9l9 5 9-5-9-5Z"/><path d="M3 14l9 5 9-5"/></svg>`,
  };

  function chipEl(text: string) {
    const s = document.createElement("span");
    s.className = "rounded-full border px-3 py-1 text-xs capitalize";
    s.style.borderColor = "var(--border-strong)";
    s.style.color = "var(--text-muted)";
    s.textContent = text;
    return s;
  }

  function noteRow(tier: string, notes: string) {
    if (!notes) return "";
    return `<div class="flex items-start gap-2.5">
      <span class="mt-0.5 shrink-0" style="color:var(--accent)">${tierIcon[tier] || ""}</span>
      <div><span class="mr-2 text-[0.62rem] font-semibold uppercase tracking-[0.14em]" style="color:var(--text-faint)">${tier}</span><span class="text-sm" style="color:var(--text-muted)">${notes}</span></div>
    </div>`;
  }

  function bottleSVG(from: string, to: string, ini: string) {
    return `<svg viewBox="0 0 200 280" class="h-full w-full" xmlns="http://www.w3.org/2000/svg"><defs><linearGradient id="dg" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="${from}"/><stop offset="100%" stop-color="${to}"/></linearGradient><linearGradient id="ds" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#fff" stop-opacity="0.55"/><stop offset="35%" stop-color="#fff" stop-opacity="0.08"/><stop offset="100%" stop-color="#fff" stop-opacity="0"/></linearGradient></defs><rect x="82" y="14" width="36" height="34" rx="4" fill="${to}"/><rect x="86" y="46" width="28" height="14" rx="2" fill="${to}" opacity="0.9"/><rect x="48" y="58" width="104" height="200" rx="18" fill="url(#dg)"/><rect x="58" y="68" width="30" height="180" rx="14" fill="url(#ds)"/><text x="100" y="172" text-anchor="middle" font-family="Fraunces, serif" font-size="34" font-weight="500" fill="#fff" fill-opacity="0.92">${ini}</text></svg>`;
  }

