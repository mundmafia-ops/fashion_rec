---
import Layout from "@/layouts/Layout.astro";
import { getFeaturedDeals, getProduct, trends } from "@/data/mock";

const featured = getFeaturedDeals();
---

<Layout>
  <main class="mx-auto max-w-5xl px-6 py-16">
    <header class="mb-12">
      <p class="text-xs uppercase tracking-[0.2em] text-neutral-500">
        Fashion · Deals · Trends · Price Tracking
      </p>
      <h1 class="mt-2 text-4xl font-semibold tracking-tight">
        The edit, before it sells out.
      </h1>
      <p class="mt-3 max-w-prose text-neutral-600">
        Scaffold ready, now on Astro. Below is mock data flowing through the
        data layer — UI to come.
      </p>
    </header>

    <section class="mb-12">
      <h2 class="mb-4 text-sm font-medium uppercase tracking-wide text-neutral-500">
        Featured deals
      </h2>
      <ul class="grid gap-4 sm:grid-cols-2">
        {
          featured.map((deal) => {
            const product = getProduct(deal.productId);
            if (!product) return null;
            return (
              <li class="rounded-lg border border-neutral-200 p-4">
                <p class="font-medium">{product.title}</p>
                <p class="text-sm text-neutral-500">{product.brand}</p>
                <p class="mt-2 text-sm">
                  <span class="font-semibold">${deal.nowPrice}</span>{" "}
                  <span class="text-neutral-400 line-through">
                    ${deal.wasPrice}
                  </span>{" "}
                  <span class="text-orange-600">−{deal.discountPct}%</span>
                </p>
              </li>
            );
          })
        }
      </ul>
    </section>

    <section>
      <h2 class="mb-4 text-sm font-medium uppercase tracking-wide text-neutral-500">
        Trending now
      </h2>
      <ul class="flex flex-wrap gap-2">
        {
          trends.map((trend) => (
            <li class="rounded-full border border-neutral-200 px-3 py-1 text-sm">
              {trend.title}
            </li>
          ))
        }
      </ul>
    </section>
  </main>
</Layout>
